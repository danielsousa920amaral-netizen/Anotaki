        function applyStudioConfig(config) {
            document.getElementById('studioNameDisplay').innerHTML = `${config.name} <span>Agendamentos</span>`;
            document.getElementById('studioNameInput').value = config.name || '';
            const phoneDisplay = document.getElementById('studioPhoneDisplay');
            if (config.phone) {
                const f = config.phone.replace(/(\d{2})(\d{2})(\d{5})(\d{4})/, '($1) $2 $3-$4');
                phoneDisplay.textContent = `📞 ${f}`;
            } else { phoneDisplay.textContent = '📞 (11) 99999-9999'; }
            document.getElementById('studioPhoneInput').value = config.phone || '';
            const pp = document.getElementById('profilePreview');
            const pa = document.getElementById('profileAvatar');
            if (config.profileImage) {
                pp.innerHTML = `<img src="${config.profileImage}" alt="Perfil" />`;
                pa.innerHTML = `<img src="${config.profileImage}" alt="Perfil" />`;
            } else { pp.innerHTML = '📷'; pa.innerHTML = '<span>📷</span>'; }
            const lp = document.getElementById('logoPreview');
            if (config.logoImage) { lp.innerHTML = `<img src="${config.logoImage}" alt="Logo" />`; }
            else { lp.innerHTML = '🏷️'; }
            window.STUDIO_PHONE = config.phone || '5511999999999';
            if (config.colors) applyColorTheme(config.colorTheme);
            updateServiceSelect(config.categories);
        }

        function handleUpload(input, preview, key) {
            if (!currentPhone) return;
            const file = input.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = (e) => {
                const base64 = e.target.result;
                preview.innerHTML = `<img src="${base64}" />`;
                const c = getStudioConfig(currentPhone);
                c[key] = base64;
                saveStudioConfig(currentPhone, c);
                if (key === 'profileImage') {
                    document.getElementById('profileAvatar').innerHTML = `<img src="${base64}" />`;
                }
                document.getElementById('configStatus').textContent = '✅ Imagem atualizada!';
                document.getElementById('configStatus').style.color = '#2e7d32';
            };
            reader.readAsDataURL(file);
        }
        document.getElementById('profileFileInput').addEventListener('change', function() {
            handleUpload(this, document.getElementById('profilePreview'), 'profileImage');
        });
        document.getElementById('logoFileInput').addEventListener('change', function() {
            handleUpload(this, document.getElementById('logoPreview'), 'logoImage');
        });

        // ============================================================
        //  ALTERAR SENHA (salão)
        // ============================================================
        document.getElementById('changePasswordBtn').addEventListener('click', () => {
            const current = document.getElementById('currentPassword').value.trim();
            const newPass = document.getElementById('newPassword').value.trim();
            const confirm = document.getElementById('confirmNewPassword').value.trim();
            const status = document.getElementById('passwordChangeStatus');
            status.textContent = '';
            status.className = 'config-status';

            if (!current || !newPass || !confirm) {
                status.textContent = '⚠️ Preencha todos os campos.';
                status.className = 'config-status error';
                return;
            }
            if (newPass.length < 4) {
                status.textContent = '⚠️ A nova senha deve ter pelo menos 4 caracteres.';
                status.className = 'config-status error';
                return;
            }
            if (newPass !== confirm) {
                status.textContent = '⚠️ As senhas não coincidem.';
                status.className = 'config-status error';
                return;
            }

            const loggedUser = JSON.parse(localStorage.getItem('loggedUser') || '{}');
            if (!loggedUser.phone) {
                status.textContent = '⚠️ Usuário não identificado.';
                status.className = 'config-status error';
                return;
            }

            const users = getUsers();
            const userIndex = users.findIndex(u => u.phone === loggedUser.phone);
            if (userIndex === -1) {
                status.textContent = '⚠️ Usuário não encontrado.';
                status.className = 'config-status error';
                return;
            }

            if (users[userIndex].password !== current) {
                status.textContent = '⚠️ Senha atual incorreta.';
                status.className = 'config-status error';
                return;
            }

            users[userIndex].password = newPass;
            saveUsers(users);

            localStorage.setItem('loggedUser', JSON.stringify({
                name: users[userIndex].name,
                phone: users[userIndex].phone,
                admin: users[userIndex].admin || false
            }));

            status.textContent = '✅ Senha alterada com sucesso!';
            status.className = 'config-status';
            document.getElementById('currentPassword').value = '';
            document.getElementById('newPassword').value = '';
            document.getElementById('confirmNewPassword').value = '';
        });

