        // ================================================================
        //   BLUETOOTH AUTOMÁTICO
        // ================================================================
        async function escanearBluetooth() {
            if (!navigator.bluetooth) {
                alert('Seu navegador não suporta Web Bluetooth. Use Chrome/Edge em HTTPS.');
                return;
            }
            const deviceList = document.getElementById('deviceList');
            const container = document.getElementById('deviceListContainer');
            const status = document.getElementById('bluetoothStatus');

            deviceList.innerHTML = '';
            container.style.display = 'block';
            deviceListVisible = true;

            try {
                status.innerHTML = '⏳ Escaneando dispositivos...';
                const device = await navigator.bluetooth.requestDevice({
                    acceptAllDevices: true,
                    optionalServices: ['battery_service', 'generic_access', '000018f0-0000-1000-8000-00805f9b34fb']
                });

                bluetoothDevice = device;
                impressoraConfig.nome = device.name || 'Dispositivo sem nome';
                impressoraConfig.endereco = device.id || '';
                impressoraConfig.senha = '';
                impressoraConfig.tipo = 'bluetooth';
                salvarImpressora();
                atualizarCamposImpressora();
                status.innerHTML = `✅ Conectado a: ${device.name || 'Dispositivo'}`;
                container.style.display = 'none';
                deviceListVisible = false;
                alert(`Conectado ao dispositivo Bluetooth: ${device.name || 'Sem nome'}`);
            } catch (error) {
                if (error.message && error.message.includes('cancelled')) {
                    status.innerHTML = '⛔ Escaneamento cancelado pelo usuário.';
                } else {
                    status.innerHTML = '❌ Erro ao escanear: ' + error.message;
                    console.error(error);
                }
                container.style.display = 'none';
                deviceListVisible = false;
            }
        }

        function cancelarEscaneamento() {
            document.getElementById('deviceListContainer').style.display = 'none';
            deviceListVisible = false;
            document.getElementById('bluetoothStatus').innerHTML = '⛔ Escaneamento cancelado.';
        }

