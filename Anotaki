                listHtml += `<p style="text-align:center; color:var(--text-muted);">Nenhum salão alugado ativo.</p>`;
            } else {
                filteredUsers.forEach((u) => {
                    const config = getStudioConfig(u.phone);
                    const appCount = getAppointments(u.phone).length;
                    const expiresAt = u.expiresAt || (u.createdAt + 30 * 24 * 60 * 60 * 1000);
