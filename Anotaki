        const GLOBAL_CONFIG_KEY = 'globalConfig';
        const DEFAULT_GLOBAL_THEME = 'auto';
        const DEFAULT_GLOBAL_COLOR_THEME = 'azul_claro';

        function getGlobalConfig() {
            const stored = localStorage.getItem(GLOBAL_CONFIG_KEY);
            if (stored) {
                try {
                    const parsed = JSON.parse(stored);
                    if (!parsed.colorTheme) parsed.colorTheme = DEFAULT_GLOBAL_COLOR_THEME;
                    if (!parsed.theme) parsed.theme = DEFAULT_GLOBAL_THEME;
                    return parsed;
                } catch { /* fallback */ }
            }
            return { theme: DEFAULT_GLOBAL_THEME, colorTheme: DEFAULT_GLOBAL_COLOR_THEME };
        }

        function saveGlobalConfig(config) {
            localStorage.setItem(GLOBAL_CONFIG_KEY, JSON.stringify(config));
        }

        // ============================================================
        //  NAMESPACE POR TELEFONE
        // ============================================================
        function getStudioConfig(phone) {
            const key = `studioConfig_${phone}`;
            const gc = getGlobalConfig();
            const defaultColors = COLOR_THEMES[gc.colorTheme]?.colors || COLOR_THEMES.azul_claro.colors;
            const def = {
                name: 'Salão',
                phone: phone,
                profileImage: null,
                logoImage: null,
                availableHours: ['09:00','10:00','11:00','12:00','13:00','14:00','15:00','16:00','17:00','18:00','19:00'],
                colorTheme: gc.colorTheme || DEFAULT_GLOBAL_COLOR_THEME,
                colors: { ...defaultColors },
                categories: ['Corte', 'Coloração', 'Escova', 'Progressiva', 'Penteado', 'Outro']
            };
            const stored = localStorage.getItem(key);
            if (stored) {
                try {
                    const parsed = JSON.parse(stored);
                    for (let k in def) {
                        if (parsed[k] === undefined) parsed[k] = def[k];
                    }
                    if (!parsed.colors || !parsed.colorTheme) {
                        parsed.colors = { ...defaultColors };
                        parsed.colorTheme = gc.colorTheme || DEFAULT_GLOBAL_COLOR_THEME;
                    }
                    if (!parsed.categories || !Array.isArray(parsed.categories)) {
                        parsed.categories = def.categories;
                    }
                    return parsed;
                } catch { return def; }
            }
            return def;
        }

        function saveStudioConfig(phone, config) {
            localStorage.setItem(`studioConfig_${phone}`, JSON.stringify(config));
        }

        function getAppointments(phone) {
            const key = `appointments_${phone}`;
            const stored = localStorage.getItem(key);
            return stored ? JSON.parse(stored) : [];
