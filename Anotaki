                    if (content) {
                        content.classList.toggle('ativo');
                        const icone = h.querySelector('.icone');
                        icone.innerHTML = content.classList.contains('ativo') ? '▲' : '▼';
                        h.setAttribute('aria-expanded', content.classList.contains('ativo'));
                    }
                });
            });

            // Fechar modais ao clicar no overlay
            document.querySelectorAll('.modal-overlay').forEach(overlay => {
                overlay.addEventListener('click', function(e) {
                    if (e.target === this) {
                        const modals = ['modalConfig', 'modalVariacoesGlobais', 'modalEditarVariacaoGlobal',
                            'modalProdutosFull', 'modalCriarProduto', 'modalEdicaoProduto',
                            'modalVariacoes', 'modalPagamento', 'modalEnvioComprovante',
                            'modalColetaContato'
                        ];
                        if (modals.some(id => this.id === id)) {
                            fecharModal(this.id);
                        }
                    }
                });
            });
        });
    </script>

</body>
</html>
