        function getOpcoesGlobais() {
            // Lê os valores atuais dos inputs
            const opcoes = [];
            document.querySelectorAll('.opcao-item').forEach(div => {
                const nome = div.querySelector('.opcao-nome-global')?.value || '';
                const preco = parseFloat(div.querySelector('.opcao-preco-global')?.value) || 0;
                if (nome.trim()) opcoes.push({ nome: nome.trim(), preco });
            });
            return opcoes;
        }

        function salvarVariacaoGlobal() {
            const nome = document.getElementById('nomeVariacaoGlobal').value.trim();
            const min = parseInt(document.getElementById('minVariacaoGlobal').value) || 0;
            const max = parseInt(document.getElementById('maxVariacaoGlobal').value) || 0;
            const ativo = document.getElementById('ativoVariacaoGlobal').checked;
            const opcoes = getOpcoesGlobais();

            if (!nome) { alert('Nome da variação é obrigatório.'); return; }
            if (!opcoes.length) { alert('Adicione pelo menos uma opção.'); return; }

            if (variacaoEditandoId !== null) {
                // Editando existente
                const v = variacoesGlobais.find(v => v.id === variacaoEditandoId);
                if (v) {
                    v.nome = nome;
                    v.min = min;
                    v.max = max;
                    v.ativo = ativo;
                    v.opcoes = opcoes;
                }
            } else {
                // Nova
                const novoId = Date.now();
                variacoesGlobais.push({ id: novoId, nome, min, max, ativo, opcoes });
            }
            salvarVariacoesGlobais();
            renderizarListaVariacoesGlobais();
            fecharModal('modalEditarVariacaoGlobal');
            // Se o modal de edição de produto estiver aberto, re-renderizar grupos
            if (document.getElementById('modalEdicaoProduto').style.display === 'flex') {
                renderizarGruposEdicao();
            }
            alert('Variação salva!');
        }

        // ================================================================
        //   GRUPOS DE VARIAÇÃO NO PRODUTO (referências globais)
        // ================================================================
        function renderizarGruposEdicao() {
            const container = document.getElementById('gruposVariacaoContainer');
            if (!container) return;
            const prod = produtos.find(p => p.id === produtoEditandoId);
            if (!prod) return;

            // grupos do produto: array de referências { id: idVariaçãoGlobal, ativo, min, max }
            const gruposProduto = prod.grupos || [];

            container.innerHTML = '';
            if (!variacoesGlobais.length) {
                container.innerHTML =
                    '<div style="color:#6c757d;">Nenhuma variação global disponível. Crie uma em Configurações > Variações Globais.</div>';
                return;
            }

            // Mostra todas as variações globais com checkbox para ativar no produto
            variacoesGlobais.forEach(v => {
                const ref = gruposProduto.find(g => g.id === v.id);
                const ativo = ref ? ref.ativo : false;
                const min = ref ? ref.min : v.min;
                const max = ref ? ref.max : v.max;

                const div = document.createElement('div');
                div.className = 'grupo-variacao';
                div.dataset.id = v.id;
                div.innerHTML = `
                    <div class="grupo-header">
                        <span style="font-weight:bold;">${v.nome}</span>
                        <div>
                            <label class="toggle-switch">
                                <input type="checkbox" class="grupo-ativo" ${ativo ? 'checked' : ''} data-id="${v.id}">
                                <span class="slider"></span>
                            </label>
                            <button class="btn-remover-grupo" data-id="${v.id}" style="background:#dc3545; border:none; color:white; padding:4px 10px; border-radius:60px; cursor:pointer;">🗑️</button>
                        </div>
                    </div>
                    <div class="regras-variacao">
                        <div class="input-group"><label>Mínimo</label><input type="number" min="0" value="${min}" class="grupo-min" data-id="${v.id}"></div>
                        <div class="input-group"><label>Máximo</label><input type="number" min="0" value="${max}" class="grupo-max" data-id="${v.id}"></div>
                    </div>
                    <div style="font-size:0.7rem; color:#555; margin-top:0.3rem;">Opções: ${v.opcoes.map(o=>`${o.nome} (+R$${o.preco.toFixed(2)})`).join(', ')}</div>
                `;
                container.appendChild(div);
            });

            // Eventos para atualizar o produto.grupos
            function atualizarGruposProduto() {
                const novosGrupos = [];
                document.querySelectorAll('.grupo-variacao').forEach(div => {
                    const id = parseInt(div.dataset.id);
                    const ativo = div.querySelector('.grupo-ativo').checked;
                    const min = parseInt(div.querySelector('.grupo-min').value) || 0;
                    const max = parseInt(div.querySelector('.grupo-max').value) || 0;
                    // Verifica se a variação global ainda existe (pode ter sido deletada)
                    const exists = variacoesGlobais.some(v => v.id === id);
                    if (exists && ativo) {
                        novosGrupos.push({ id, ativo, min, max });
                    } else if (exists && !ativo) {
                        // Se estiver desativado, não adiciona (mas mantém referência? Vamos adicionar com ativo=false)
                        novosGrupos.push({ id, ativo: false, min, max });
                    }
                    // Se a variação não existe mais, ignoramos
                });
                // Salvar no produto
                const prodAtual = produtos.find(p => p.id === produtoEditandoId);
                if (prodAtual) {
                    prodAtual.grupos = novosGrupos;
                    salvarProdutos();
                }
            }

            document.querySelectorAll('.grupo-ativo').forEach(chk => {
                chk.onchange = function() {
                    atualizarGruposProduto();
                    // Re-renderizar para atualizar a exibição (opcional)
                    // renderizarGruposEdicao(); // Evitar loop
                };
            });
            document.querySelectorAll('.grupo-min').forEach(inp => {
                inp.onchange = function() { atualizarGruposProduto(); };
            });
            document.querySelectorAll('.grupo-max').forEach(inp => {
                inp.onchange = function() { atualizarGruposProduto(); };
            });
            document.querySelectorAll('.btn-remover-grupo').forEach(btn => {
                btn.onclick = function() {
                    const id = parseInt(this.dataset.id);
                    const prodAtual = produtos.find(p => p.id === produtoEditandoId);
                    if (prodAtual) {
                        prodAtual.grupos = prodAtual.grupos.filter(g => g.id !== id);
                        salvarProdutos();
                        renderizarGruposEdicao();
                    }
                };
            });
        }

