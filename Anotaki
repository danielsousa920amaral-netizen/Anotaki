                    if (!target) return;
                    if (target.textContent === '••••••••' || target.textContent.includes('•')) {
                        target.textContent = btn.dataset.pass;
                        btn.textContent = '🙈';
                    } else {
                        target.textContent = '•'.repeat(btn.dataset.pass.length);
                        btn.textContent = '👁️';
                    }
                });
            });

            document.getElementById('refreshSuperAdmin')?.addEventListener('click', renderSuperAdminDashboard);

            document.getElementById('openGlobalSettings')?.addEventListener('click', () => {
                const gc = getGlobalConfig();
                const currentOwner = getOwnerWhatsApp();
                const modalHtml = `
                    <div style="position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); backdrop-filter:blur(4px); z-index:3000; display:flex; justify-content:center; align-items:center;">
