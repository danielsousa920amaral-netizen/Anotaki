        function renderHoursCheckboxes(selectedHours) {
            const container = document.getElementById('hoursCheckboxesContainer');
            if (!container) return;
            container.innerHTML = '';
            const ALL_HOURS = [];
            for (let h = 8; h <= 20; h++) ALL_HOURS.push(`${String(h).padStart(2, '0')}:00`);
            ALL_HOURS.forEach(hour => {
                const checked = selectedHours.includes(hour) ? 'checked' : '';
                const label = document.createElement('label');
                label.innerHTML = `<input type="checkbox" value="${hour}" ${checked}> ${hour}`;
                container.appendChild(label);
            });
        }

        document.getElementById('saveSettingsBtn').addEventListener('click', () => {
            if (!currentPhone) return;
            const name = document.getElementById('studioNameInput').value.trim();
            const phone = document.getElementById('studioPhoneInput').value.trim();
            const status = document.getElementById('configStatus');

            const checkboxes = document.querySelectorAll('#hoursCheckboxesContainer input[type="checkbox"]');
            const selectedHours = [];
            checkboxes.forEach(cb => { if (cb.checked) selectedHours.push(cb.value); });

            if (!name) { status.textContent = '⚠️ Informe o nome do salão.'; status.style.color = '#c62828'; return; }
            if (!phone || !/^\d{10,13}$/.test(phone)) {
                status.textContent = '⚠️ Número inválido (somente números, DDD + número).';
                status.style.color = '#c62828'; return;
            }
            if (selectedHours.length === 0) {
                status.textContent = '⚠️ Selecione pelo menos um horário disponível.';
                status.style.color = '#c62828'; return;
            }

            const selectedThemeEl = document.querySelector('.theme-option.selected');
            let colorTheme = getGlobalConfig().colorTheme || DEFAULT_GLOBAL_COLOR_THEME;
            if (selectedThemeEl) {
                colorTheme = selectedThemeEl.dataset.theme;
            }
            const colors = { ...COLOR_THEMES[colorTheme]?.colors || COLOR_THEMES.azul_claro.colors };

            const c = getStudioConfig(currentPhone);
            c.name = name;
            c.phone = phone;
            c.availableHours = selectedHours;
            c.colorTheme = colorTheme;
            c.colors = colors;
            saveStudioConfig(currentPhone, c);
            const loggedUser = JSON.parse(localStorage.getItem('loggedUser') || '{}');
            if (loggedUser.phone === currentPhone) {
                applyColorTheme(colorTheme);
                applyStudioConfig(c);
            }
            applyTheme(document.getElementById('themeSelect').value);
            applyResolution(document.getElementById('resolutionSelect').value);
            status.textContent = '✅ Configurações salvas!';
            status.style.color = '#2e7d32';
            if (typeof renderAll === 'function' && loggedUser.phone === currentPhone) renderAll();
            setTimeout(() => settingsOverlay.classList.remove('open'), 1000);
