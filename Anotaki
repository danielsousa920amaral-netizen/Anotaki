<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes" />
    <title>Estúdio Claudineia - Agendamentos</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300..700&display=swap" rel="stylesheet" />
    <style>
        /* ===== BASE ===== */
        :root {
            --primary: #8B5A7E;
            --primary-light: #B28AA8;
            --primary-dark: #6A405E;
            --bg-body: #F9F5F8;
            --bg-container: #ffffff;
            --text-primary: #3D2A3A;
            --text-secondary: #6F5A6A;
            --text-muted: #A0879A;
            --card-bg: #F7F0F5;
            --card-hover: #EDE0E8;
            --border-color: #E3D6DE;
            --shadow: 0 20px 50px rgba(90,60,80,0.15);
            --shadow-hover: 0 25px 60px rgba(90,60,80,0.25);
            --radius: 28px;
            --font-family: 'Inter', sans-serif;
            --container-max-width: 1100px;
            --hour-grid-cols: 4;
            --transition: 0.25s cubic-bezier(0.4,0,0.2,1);
        }
        [data-theme="dark"] {
            --bg-body: #1A1520;
            --bg-container: rgba(30,25,38,0.92);
            --text-primary: #EDE4F0;
            --text-secondary: #C4B6C8;
            --text-muted: #A08E9E;
            --card-bg: #2F2638;
            --card-hover: #3F334A;
            --border-color: #4A3D52;
            --shadow: 0 20px 50px rgba(0,0,0,0.6);
            --shadow-hover: 0 25px 60px rgba(0,0,0,0.7);
            --primary: #8B5A7E;
            --primary-light: #B28AA8;
            --primary-dark: #6A405E;
            --bg-body: #1A1520;
            --bg-container: rgba(30,25,38,0.92);
            --text-primary: #EDE4F0;
            --text-secondary: #C4B6C8;
            --card-bg: #2F2638;
            --card-hover: #3F334A;
            --border-color: #4A3D52;
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        html { font-size: 100%; }
        body {
            font-family: var(--font-family);
            background: var(--bg-body);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 24px;
            transition: background var(--transition), color var(--transition);
            line-height: 1.5;
            font-size: 1rem;
        }
        .container {
            max-width: var(--container-max-width);
            width: 100%;
            background: var(--bg-container);
            backdrop-filter: blur(12px);
            padding: 36px 40px 40px;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            border: 1px solid rgba(255,255,255,0.25);
            display: none;
            transition: all var(--transition);
        }
        .container.active { display: block; animation: fadeUp 0.5s ease; }
        @keyframes fadeUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }

        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 16px;
            margin-bottom: 6px;
        }
        .top-bar .brand {
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .top-bar .brand .avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: var(--card-bg);
            border: 2px solid var(--border-color);
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            color: var(--text-muted);
            flex-shrink: 0;
        }
        .top-bar .brand .avatar img { width:100%; height:100%; object-fit:cover; }
        .top-bar .brand .studio-info h1 {
            color: var(--text-primary);
            font-size: 1.8rem;
            font-weight: 700;
            letter-spacing: -0.5px;
            line-height: 1.2;
        }
        .top-bar .brand .studio-info h1 span {
            background: var(--primary);
            color: #fff;
            font-size: 0.6rem;
            font-weight: 600;
            padding: 2px 10px;
            border-radius: 40px;
            margin-left: 6px;
        }
        .top-bar .brand .studio-info .studio-phone {
            font-size: 0.8rem;
            color: var(--text-secondary);
        }
        .top-bar .actions {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }
        .top-bar .btn-settings {
            background: transparent;
            border: none;
            font-size: 1.6rem;
            cursor: pointer;
            color: var(--text-secondary);
            padding: 6px 10px;
            border-radius: 40px;
            transition: background var(--transition), transform var(--transition);
            line-height: 1;
        }
        .top-bar .btn-settings:hover {
            background: var(--card-hover);
            transform: rotate(30deg);
        }
        .top-bar .btn-refresh {
            background: transparent;
            border: none;
            font-size: 1.3rem;
            cursor: pointer;
            color: var(--text-secondary);
            padding: 6px 10px;
            border-radius: 40px;
            transition: all var(--transition);
            line-height: 1;
        }
        .top-bar .btn-refresh:hover {
            background: var(--card-hover);
            transform: rotate(45deg);
        }
        .top-bar .btn-gestao {
            background: transparent;
            border: none;
            font-size: 1.3rem;
            cursor: pointer;
            color: var(--text-secondary);
            padding: 6px 10px;
            border-radius: 40px;
            transition: all var(--transition);
            line-height: 1;
        }
        .top-bar .btn-gestao:hover {
            background: var(--card-hover);
            transform: scale(1.1);
        }
        .top-bar .theme-selector {
            display: flex;
            align-items: center;
            gap: 4px;
            background: var(--card-bg);
            border-radius: 40px;
            padding: 4px 8px;
            border: 1px solid var(--border-color);
        }
        .top-bar .theme-selector button {
            background: transparent;
            border: none;
            border-radius: 30px;
            padding: 4px 10px;
            font-size: 0.85rem;
            cursor: pointer;
            color: var(--text-secondary);
            font-weight: 500;
            transition: all var(--transition);
            font-family: var(--font-family);
        }
        .top-bar .theme-selector button.active {
            background: var(--primary);
            color: #fff;
        }
        .top-bar .theme-selector button:hover:not(.active) {
            background: var(--card-hover);
        }
        .mode-selector {
            display: flex;
            align-items: center;
            gap: 4px;
            background: var(--card-bg);
            border-radius: 40px;
            padding: 4px 4px;
            border: 1px solid var(--border-color);
        }
        .mode-selector button {
            background: transparent;
            border: none;
            border-radius: 30px;
            padding: 4px 12px;
            font-size: 0.8rem;
            cursor: pointer;
            color: var(--text-secondary);
            font-weight: 500;
            transition: all var(--transition);
            font-family: var(--font-family);
        }
        .mode-selector button.active {
            background: var(--primary);
            color: #fff;
        }
        .mode-selector button:hover:not(.active) {
            background: var(--card-hover);
        }
        .btn-logout {
            background: transparent;
            color: var(--text-secondary);
            border: 1.5px solid var(--border-color);
            border-radius: 40px;
            padding: 8px 20px;
            font-weight: 600;
            font-size: 0.85rem;
            cursor: pointer;
            transition: all var(--transition);
            font-family: var(--font-family);
        }
        .btn-logout:hover {
            background: var(--primary);
            color: #fff;
            border-color: var(--primary);
            transform: scale(1.02);
        }
        .subtitle {
            text-align: center;
            color: var(--text-secondary);
            margin: 4px 0 32px;
            font-weight: 400;
            font-size: 1rem;
            border-bottom: 2px dashed var(--border-color);
            padding-bottom: 14px;
        }
        .flex-row { display: flex; flex-wrap: wrap; gap: 36px; }
        .col { flex: 1 1 320px; }
        .calendar-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 18px;
        }
        .calendar-header button {
            background: var(--card-bg);
            color: var(--text-primary);
            border: none;
            border-radius: 40px;
            padding: 8px 18px;
            font-weight: 600;
            font-size: 1.2rem;
            cursor: pointer;
            transition: all var(--transition);
            font-family: var(--font-family);
        }
        .calendar-header button:hover {
            background: var(--primary);
            color: #fff;
            transform: scale(1.05);
        }
        .calendar-header span {
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--text-primary);
            text-transform: capitalize;
        }
        .weekdays {
            display: grid;
            grid-template-columns: repeat(7,1fr);
            text-align: center;
            font-weight: 600;
            font-size: 0.8rem;
            color: var(--text-secondary);
            margin-bottom: 8px;
        }
        .days-grid {
            display: grid;
            grid-template-columns: repeat(7,1fr);
            gap: 5px;
        }
        .day-cell {
            aspect-ratio: 1/1;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 40px;
            font-weight: 500;
            font-size: 0.9rem;
            background: var(--card-bg);
            cursor: pointer;
            transition: all var(--transition);
            color: var(--text-primary);
            position: relative;
            user-select: none;
        }
        .day-cell:hover { background: var(--card-hover); transform: scale(1.04); }
        .day-cell.selected {
            background: var(--primary);
            color: #fff;
            font-weight: 600;
            box-shadow: 0 6px 18px rgba(139,90,126,0.35);
            transform: scale(1.02);
        }
        .day-cell.other-month { opacity:0.3; pointer-events:none; }
        .day-cell.today { border:2px solid var(--primary); font-weight:600; }
        .day-cell.has-appointment::after {
            content: '';
            display: block;
            width: 7px;
            height: 7px;
            background: var(--primary);
            border-radius: 50%;
            position: absolute;
            bottom: 5px;
            left: 50%;
            transform: translateX(-50%);
        }
        .day-cell.has-appointment.selected::after { background: #fff; }
        .hours-section { margin-top: 22px; }
        .hours-section h3 {
            color: var(--text-primary);
            margin-bottom: 12px;
            font-weight: 600;
            font-size: 1rem;
        }
        .hours-grid {
            display: grid;
            grid-template-columns: repeat(var(--hour-grid-cols),1fr);
            gap: 8px;
        }
        .hour-btn {
            background: var(--card-bg);
            border: none;
            border-radius: 40px;
            padding: 10px 0;
            font-weight: 500;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all var(--transition);
            color: var(--text-primary);
            font-family: var(--font-family);
            border: 1.5px solid transparent;
        }
        .hour-btn:hover:not(:disabled) {
            background: var(--card-hover);
            transform: translateY(-2px);
        }
        .hour-btn.booked {
            background: var(--card-bg);
            color: var(--text-muted);
            cursor: not-allowed;
            text-decoration: line-through;
            opacity: 0.5;
        }
        .hour-btn.selected-hour {
            background: var(--primary);
            color: #fff;
            box-shadow: 0 6px 18px rgba(139,90,126,0.3);
            transform: scale(1.02);
            border-color: var(--primary);
        }
        .hour-btn:disabled { cursor:not-allowed; opacity:0.45; }
        .col h3 {
            color: var(--text-primary);
            margin-bottom: 16px;
            font-weight: 600;
            font-size: 1.1rem;
        }
        .form-group { margin-bottom: 16px; }
        .form-group label {
            display: block;
            font-weight: 500;
            color: var(--text-primary);
            margin-bottom: 5px;
            font-size: 0.9rem;
        }
        .form-group input, .form-group select {
            width: 100%;
            padding: 12px 18px;
            border-radius: 40px;
            border: 1.5px solid var(--border-color);
            background: #fff;
            font-size: 0.95rem;
            outline: none;
            transition: border var(--transition), box-shadow var(--transition);
            color: var(--text-primary);
            font-family: var(--font-family);
        }
        .form-group input:focus, .form-group select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(139,90,126,0.15);
        }
        .form-group input::placeholder { color: var(--text-muted); }
        .form-group input[readonly] {
            background: var(--card-bg);
            cursor: default;
        }
        .btn-primary {
            background: var(--primary);
            color: #fff;
            border: none;
            border-radius: 40px;
            padding: 14px 28px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: all var(--transition);
            width: 100%;
            font-family: var(--font-family);
        }
        .btn-primary:hover {
            background: var(--primary-dark);
            transform: scale(1.01);
            box-shadow: 0 8px 24px rgba(139,90,126,0.3);
        }
        .btn-whatsapp {
            background: #25D366;
            color: #fff;
            border: none;
            border-radius: 40px;
            padding: 14px 28px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: all var(--transition);
            width: 100%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            text-decoration: none;
            margin-top: 12px;
            font-family: var(--font-family);
        }
        .btn-whatsapp:hover {
            background: #1da851;
            transform: scale(1.02);
            box-shadow: 0 8px 24px rgba(37,211,102,0.3);
        }
        .status-msg {
            text-align: center;
            margin-top: 14px;
            font-weight: 500;
            font-size: 0.95rem;
            color: #2e7d32;
            padding: 4px 0;
        }
        .status-msg.error { color: #c62828; }
        .appointments-list {
            margin-top: 34px;
            border-top: 2px dashed var(--border-color);
            padding-top: 24px;
        }
        .appointments-list h3 {
            color: var(--text-primary);
            margin-bottom: 16px;
            font-weight: 600;
            font-size: 1.1rem;
        }
        .appointment-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--card-bg);
            padding: 14px 20px;
            border-radius: 40px;
            margin-bottom: 10px;
            flex-wrap: wrap;
            gap: 10px;
            transition: all var(--transition);
            border: 2px solid transparent;
        }
        .appointment-item:hover {
            border-color: var(--border-color);
            transform: translateX(4px);
        }
        .appointment-item.pending {
            border-color: #e65100;
            background: #fff3e0;
        }
        .appointment-item.confirmed {
            border-color: #2e7d32;
            background: #e8f5e9;
        }
        .appointment-info {
            display: flex;
            flex-wrap: wrap;
            gap: 6px 20px;
            font-size: 0.9rem;
            color: var(--text-primary);
        }
        .appointment-info strong { color: var(--primary); font-weight:600; }
        .appointment-status {
            font-size: 0.75rem;
            font-weight: 600;
            padding: 2px 12px;
            border-radius: 30px;
            background: var(--card-bg);
        }
        .appointment-status.confirmed {
            background: #e8f5e9;
            color: #2e7d32;
        }
        .appointment-status.pending {
            background: #fff3e0;
            color: #e65100;
        }
        .no-appointments {
            color: var(--text-muted);
            font-style: italic;
            text-align: center;
            padding: 20px 0;
        }
        .btn-danger {
            background: rgba(211,47,47,0.12);
            color: #c62828;
            border: none;
            border-radius: 30px;
            padding: 6px 16px;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            transition: all var(--transition);
            font-family: var(--font-family);
        }
        .btn-danger:hover {
            background: #c62828;
            color: #fff;
            transform: scale(1.04);
        }
        .btn-success {
            background: rgba(46,125,50,0.12);
            color: #2e7d32;
            border: none;
            border-radius: 30px;
            padding: 6px 16px;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            transition: all var(--transition);
            font-family: var(--font-family);
        }
        .btn-success:hover {
            background: #2e7d32;
            color: #fff;
            transform: scale(1.04);
        }
        .btn-whatsapp-small {
            background: #25D366;
            color: #fff;
            border: none;
            border-radius: 30px;
            padding: 6px 16px;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            transition: all var(--transition);
            font-family: var(--font-family);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }
        .btn-whatsapp-small:hover {
            background: #1da851;
            transform: scale(1.04);
        }
        .btn-value {
            background: rgba(33,150,243,0.12);
            color: #0d47a1;
            border: none;
            border-radius: 30px;
            padding: 6px 16px;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            transition: all var(--transition);
            font-family: var(--font-family);
        }
        .btn-value:hover {
            background: #0d47a1;
            color: #fff;
            transform: scale(1.04);
        }
        .whatsapp-area { margin-top: 8px; text-align:center; }
        .admin-title {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .badge-pending {
            background: #e65100;
            color: #fff;
            border-radius: 30px;
            padding: 2px 12px;
            font-size: 0.75rem;
            font-weight: 600;
        }
        .alert-box {
            background: #fff3e0;
            border-left: 4px solid #e65100;
            padding: 10px 16px;
            border-radius: 12px;
            margin-bottom: 16px;
            color: #e65100;
            font-weight: 500;
        }
        .alert-box strong { font-weight: 700; }

        /* GESTÃO MODAL */
        .gestao-overlay {
            display: none;
            position: fixed;
            top:0; left:0; width:100%; height:100%;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(6px);
            z-index:1500;
            justify-content:center;
            align-items:center;
            padding:20px;
        }
        .gestao-overlay.open { display:flex; animation:fadeIn 0.3s ease; }
        .gestao-modal {
            background: var(--bg-container);
            backdrop-filter: blur(12px);
            padding: 34px 32px 32px;
            border-radius: var(--radius);
            max-width: 900px;
            width:100%;
            max-height:90vh;
            overflow-y:auto;
            box-shadow: var(--shadow-hover);
            color: var(--text-primary);
            border:1px solid var(--border-color);
            animation:slideUp 0.3s ease;
        }
        .gestao-modal h2 {
            text-align:center;
            margin-bottom:24px;
            font-weight:700;
            font-size:1.6rem;
        }
        .gestao-tabs {
            display: flex;
            gap: 8px;
            border-bottom: 2px solid var(--border-color);
            padding-bottom: 12px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }
        .gestao-tabs button {
            background: transparent;
            border: none;
            padding: 8px 20px;
            border-radius: 40px;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            color: var(--text-secondary);
            transition: all var(--transition);
            font-family: var(--font-family);
        }
        .gestao-tabs button.active {
            background: var(--primary);
            color: #fff;
        }
        .gestao-tabs button:hover:not(.active) {
            background: var(--card-hover);
        }
        .gestao-content {
            min-height: 300px;
        }
        .gestao-content .tab-pane { display: none; }
        .gestao-content .tab-pane.active { display: block; }
        .gestao-content .form-row {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            align-items: flex-end;
        }
        .gestao-content .form-row .form-group {
            flex: 1 1 160px;
            margin-bottom: 0;
        }
        .gestao-content .form-row .form-group label { font-size:0.8rem; }
        .gestao-content .form-row .form-group input { padding:8px 12px; }
        .gestao-content .btn-primary { width:auto; padding:8px 24px; }
        .gestao-content .lista-transacoes {
            margin-top: 16px;
        }
        .gestao-content .transacao-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--card-bg);
            padding: 10px 16px;
            border-radius: 40px;
            margin-bottom: 8px;
            flex-wrap: wrap;
            gap: 8px;
        }
        .gestao-content .transacao-item .info {
            display: flex;
            flex-wrap: wrap;
            gap: 6px 16px;
            font-size:0.9rem;
        }
        .gestao-content .transacao-item .info .valor {
            font-weight: 600;
            color: var(--primary);
        }
        .gestao-content .transacao-item .info .tipo {
            font-weight: 500;
        }
        .gestao-content .transacao-item .info .tipo.entrada { color: #2e7d32; }
        .gestao-content .transacao-item .info .tipo.saida { color: #c62828; }
        .gestao-content .totalizador {
            background: var(--card-bg);
            border-radius: 16px;
            padding: 16px 20px;
            margin-bottom: 16px;
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            border: 1px solid var(--border-color);
        }
        .gestao-content .totalizador .item {
            flex: 1 1 120px;
        }
        .gestao-content .totalizador .item .label {
            font-size:0.8rem;
            color:var(--text-muted);
        }
        .gestao-content .totalizador .item .value {
            font-size:1.4rem;
            font-weight:700;
            color:var(--text-primary);
        }
        .gestao-content .totalizador .item .value.positive { color:#2e7d32; }
        .gestao-content .totalizador .item .value.negative { color:#c62828; }
        .gestao-modal .btn-close {
            margin-top:20px;
