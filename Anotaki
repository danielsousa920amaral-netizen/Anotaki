        // ================================================================
        function abrirPagamento() {
            if (!carrinho.length) { alert('Carrinho vazio'); return; }
            const total = carrinho.reduce((s, i) => s + i.precoUnitario * i.quantidade, 0);
            ultimoTotal = total;
            let resumoHtml = '<div style="font-weight:bold;">📋 Itens do pedido:</div>';
            carrinho.forEach(item => {
                resumoHtml +=
                    `<div><strong>${item.nome}</strong> x${item.quantidade} = R$ ${(item.precoUnitario*item.quantidade).toFixed(2)}</div>`;
                if (item.variacoes && item.variacoes.length) resumoHtml +=
                    `<div style="font-size:0.7rem;">📌 ${item.variacoes.map(g=>`${g.nomeGrupo}: ${g.itens.map(i=>i.nome).join(', ')}`).join(' | ')}</div>`;
            });
            resumoHtml += `<div style="text-align:right; font-weight:bold;">💰 TOTAL: R$ ${total.toFixed(2)}</div>`;
            document.getElementById('resumoPedidoDetalhado').innerHTML = resumoHtml;
            const pixKey = dadosBanco.pix || "chave@exemplo.com";
            document.getElementById('pixChaveMostrar').innerHTML = `✨ Chave PIX: <strong>${pixKey}</strong>`;
            gerarQRCodeReal(pixKey);
            document.getElementById('detalhePagamento').style.display = 'none';
            document.getElementById('pixDetalhe').style.display = 'none';
            pagamentoSelecionado = null;
            abrirModal('modalPagamento');
        }

        function selecionarPagamento(tipo) {
            pagamentoSelecionado = tipo;
            if (tipo === 'pix') {
                document.getElementById('detalhePagamento').style.display = 'none';
                document.getElementById('pixDetalhe').style.display = 'block';
            } else {
                document.getElementById('detalhePagamento').style.display = 'block';
                document.getElementById('pixDetalhe').style.display = 'none';
            }
        }

        function confirmarPagamento() {
            if (!pagamentoSelecionado) { alert('Selecione uma forma de pagamento!'); return; }

            if (pagamentoSelecionado !== 'pix') {
                const num = document.getElementById('cardNumber').value.trim();
                const nome = document.getElementById('cardName').value.trim();
                const val = document.getElementById('cardValidade').value.trim();
                const cvv = document.getElementById('cardCvv').value.trim();
                if (!num || !nome || !val || !cvv) {
                    alert('Preencha todos os dados do cartão.');
                    return;
                }
                if (cvv.length < 3) { alert('CVV inválido.'); return; }
            }

            const total = ultimoTotal;
            const dataHora = new Date().toLocaleString('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric',
                hour: '2-digit', minute: '2-digit', second: '2-digit' });
            let comprovanteHtml =
                `<div class="comprovante"><h3>🍓 Açaí & Tapioca da Thainá</h3><div class="info">Pedido: #${numeroPedido}</div><div class="info">Data: ${dataHora}</div><div class="info">Pagamento: ${pagamentoSelecionado.toUpperCase()}</div><hr><div class="items">`;
            carrinho.forEach(item => {
                comprovanteHtml +=
                    `<div class="linha"><span>${item.nome} x${item.quantidade}</span><span>R$ ${(item.precoUnitario * item.quantidade).toFixed(2)}</span></div>`;
                if (item.variacoes && item.variacoes.length) {
                    item.variacoes.forEach(grupo => {
                        comprovanteHtml +=
                            `<div class="variacao">📌 ${grupo.nomeGrupo}: ${grupo.itens.map(i => i.nome).join(', ')}</div>`;
                    });
                }
            });
            const subtotal = carrinho.reduce((s, i) => s + i.precoUnitario * i.quantidade, 0);
            comprovanteHtml +=
                `<hr><div class="linha"><span>SUBTOTAL</span><span>R$ ${subtotal.toFixed(2)}</span></div><div class="linha"><span>TOTAL</span><span>R$ ${total.toFixed(2)}</span></div><hr><div class="info">💙 Obrigado!</div></div></div>`;
            comprovanteGerado = comprovanteHtml;

            carrinho = [];
            salvarCarrinho();
            renderizarPedido();
            atualizarTotalFlutuante();
            atualizarBadgeCarrinho();
            numeroPedido++;
            salvarNumeroPedido();
            fecharModal('modalPagamento');

            const modalImpressao = document.getElementById('modalImpressao');
            modalImpressao.style.display = 'flex';
            setTimeout(() => {
                const win = window.open('', '_blank');
                win.document.write(
                    `<html><head><title>Comprovante Pedido #${numeroPedido-1}</title><style>@media print { body { margin: 0; } .comprovante { width: 80mm; margin: 0 auto; } }</style></head><body>${comprovanteGerado}</body></html>`
                );
                win.print();
                modalImpressao.style.display = 'none';
                setTimeout(() => {
                    if (confirm('Comprovante impresso! Deseja enviar também por e-mail ou WhatsApp?')) {
                        abrirModal('modalEnvioComprovante');
                    }
                }, 500);
            }, 1000);
        }

        function prepararEnvio(tipo) {
            if (tipo === 'imprimir') {
                const win = window.open('', '_blank');
                win.document.write(
                    `<html><head><title>Comprovante</title><style>@media print { body { margin: 0; } .comprovante { width: 80mm; margin: 0 auto; } }</style></head><body>${comprovanteGerado}</body></html>`
                );
                win.print();
                fecharModal('modalEnvioComprovante');
            } else if (tipo === 'email') {
                document.getElementById('coletaTitulo').innerText = 'Enviar comprovante por e-mail';
                document.getElementById('coletaLabel').innerText = 'E-mail:';
                document.getElementById('contatoValor').value = '';
                abrirModal('modalColetaContato');
            } else if (tipo === 'whatsapp') {
                document.getElementById('coletaTitulo').innerText = 'Enviar comprovante por WhatsApp';
                document.getElementById('coletaLabel').innerText = 'WhatsApp (com DDD):';
                document.getElementById('contatoValor').value = '';
                abrirModal('modalColetaContato');
            }
        }

        function enviarComprovante() {
            const contato = document.getElementById('contatoValor').value.trim();
            if (!contato) { alert('Informe o contato'); return; }
            if (tipoEnvio === 'email') {
                const assunto = encodeURIComponent(`Comprovante de pedido #${numeroPedido-1}`);
                const corpo = encodeURIComponent(comprovanteGerado.replace(/<[^>]*>/g, '\n'));
                window.location.href = `mailto:${contato}?subject=${assunto}&body=${corpo}`;
                alert(`E-mail aberto para envio a ${contato}.`);
            } else if (tipoEnvio === 'whatsapp') {
                let numero = contato.replace(/\D/g, '');
                if (!numero.startsWith('55')) numero = '55' + numero;
                const mensagem = encodeURIComponent(comprovanteGerado.replace(/<[^>]*>/g, '\n').replace(/&nbsp;/g, ' '));
                window.open(`https://wa.me/${numero}?text=${mensagem}`, '_blank');
                alert(`Mensagem preparada para o WhatsApp ${contato}.`);
            }
            fecharModal('modalColetaContato');
            fecharModal('modalEnvioComprovante');
        }

