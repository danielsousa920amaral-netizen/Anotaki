        // ============================================================
        //  USERS (com admin padrão garantido)
        // ============================================================
        function getUsers() {
            let users = JSON.parse(localStorage.getItem('users')) || [];
            // Verifica se o admin padrão existe
            const adminExists = users.some(u => u.phone === DEFAULT_ADMIN.phone);
            if (!adminExists) {
                const now = Date.now();
                users.unshift({
                    name: DEFAULT_ADMIN.name,
                    phone: DEFAULT_ADMIN.phone,
                    password: DEFAULT_ADMIN.password,
                    admin: true,
                    createdAt: now,
                    expiresAt: now + 30 * 24 * 60 * 60 * 1000,
                    blocked: false
                });
                localStorage.setItem('users', JSON.stringify(users));
            }
            return users;
        }

        function saveUsers(u) {
            localStorage.setItem('users', JSON.stringify(u));
        }

        // ============================================================
        //  APLICAÇÃO DE CORES E TEMA
        // ============================================================
        function applyColorTheme(themeKey) {
            const theme = COLOR_THEMES[themeKey];
            if (!theme) return;
            const colors = theme.colors;
            const root = document.documentElement;
            root.style.setProperty('--primary', colors.primary);
            root.style.setProperty('--primary-light', colors.primaryLight);
            root.style.setProperty('--primary-dark', colors.primaryDark);
            root.style.setProperty('--bg-body', colors.bgBody);
            root.style.setProperty('--bg-container', colors.bgContainer);
            root.style.setProperty('--text-primary', colors.textPrimary);
            root.style.setProperty('--text-secondary', colors.textSecondary);
            root.style.setProperty('--text-muted', colors.textMuted);
            root.style.setProperty('--card-bg', colors.cardBg);
            root.style.setProperty('--card-hover', colors.cardHover);
            root.style.setProperty('--border-color', colors.borderColor);
        }

        function applyTheme(t) {
            if (t === 'auto') {
                const dark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
            } else { document.documentElement.setAttribute('data-theme', t); }
            localStorage.setItem('theme', t);
            document.querySelectorAll('#quickThemeSelector button').forEach(btn => {
                btn.classList.toggle('active', btn.dataset.theme === t);
            });
        }

        function applyResolution(r) {
            if (r === 'auto') document.documentElement.removeAttribute('data-resolution');
            else document.documentElement.setAttribute('data-resolution', r);
            localStorage.setItem('resolution', r);
        }

        function loadThemeRes() {
            const t = localStorage.getItem('theme') || 'auto';
            const r = localStorage.getItem('resolution') || 'auto';
            document.getElementById('themeSelect').value = t;
            document.getElementById('resolutionSelect').value = r;
            applyTheme(t);
            applyResolution(r);
        }

        // ============================================================
        //  RENDER SELETOR DE CORES
        // ============================================================
        function renderColorThemeSelector(selectedKey) {
            const container = document.getElementById('colorThemeSelector');
            if (!container) return;
            container.innerHTML = '';
            for (let key in COLOR_THEMES) {
                const theme = COLOR_THEMES[key];
                const isSelected = key === selectedKey;
                const div = document.createElement('div');
                div.className = `theme-option ${isSelected ? 'selected' : ''}`;
                div.dataset.theme = key;
                div.innerHTML = `
                    <div class="color-swatch" style="background:${theme.colors.primary}; color:${theme.colors.bgBody};">
                        ${theme.icon}
                    </div>
                    <span class="color-name">${theme.name}</span>
                `;
                div.addEventListener('click', () => {
                    document.querySelectorAll('.theme-option').forEach(el => el.classList.remove('selected'));
                    div.classList.add('selected');
                    applyColorTheme(key);
                    if (currentPhone) {
                        const c = getStudioConfig(currentPhone);
                        c.colorTheme = key;
                        c.colors = { ...COLOR_THEMES[key].colors };
                        saveStudioConfig(currentPhone, c);
                        document.getElementById('themeStatus').textContent = '✅ Tema aplicado e salvo!';
                        document.getElementById('themeStatus').className = 'config-status';
                        document.getElementById('themeStatus').style.color = '#2e7d32';
                    }
                });
                container.appendChild(div);
            }
        }

        // ============================================================
        //  CATEGORIAS
        // ============================================================
        function renderCategories(categories) {
            const container = document.getElementById('categoryList');
            if (!container) return;
            container.innerHTML = '';
            if (!categories || categories.length === 0) {
                container.innerHTML = '<span style="color:var(--text-muted);font-size:0.85rem;">Nenhuma categoria cadastrada.</span>';
                return;
            }
            categories.forEach((cat, idx) => {
                const tag = document.createElement('span');
                tag.className = 'category-tag';
                tag.innerHTML = `${cat} <button class="remove-cat" data-idx="${idx}">×</button>`;
                container.appendChild(tag);
            });
            document.querySelectorAll('.remove-cat').forEach(btn => {
                btn.addEventListener('click', () => {
                    const idx = parseInt(btn.dataset.idx);
                    if (!currentPhone) return;
                    const c = getStudioConfig(currentPhone);
                    c.categories.splice(idx, 1);
                    saveStudioConfig(currentPhone, c);
                    renderCategories(c.categories);
                    updateServiceSelect(c.categories);
                    document.getElementById('categoryStatus').textContent = '✅ Categoria removida!';
                    document.getElementById('categoryStatus').className = 'config-status';
                });
            });
        }

        function updateServiceSelect(categories) {
            const select = document.getElementById('service');
            if (!select) return;
            select.innerHTML = '';
            if (!categories || categories.length === 0) {
                const opt = document.createElement('option');
                opt.value = '';
                opt.textContent = 'Nenhuma categoria cadastrada';
                opt.disabled = true;
                opt.selected = true;
                select.appendChild(opt);
                return;
            }
            categories.forEach(cat => {
                const opt = document.createElement('option');
                opt.value = cat;
                opt.textContent = cat;
                select.appendChild(opt);
            });
        }

