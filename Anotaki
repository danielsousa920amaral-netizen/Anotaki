                                <small style="color:var(--text-muted);font-size:0.75rem;">Somente números, com DDD (ex: 5511999999999)</small>
                            </div>
                            <div style="display:flex; gap:10px; margin-top:12px;">
                                <button class="btn-primary" id="saveGlobalConfigBtn" style="flex:1;">Salvar</button>
                                <button class="btn-secondary" id="closeGlobalConfigBtn" style="flex:1;">Cancelar</button>
                            </div>
                        </div>
                    </div>
                `;
                const overlay = document.createElement('div');
                overlay.id = 'globalConfigOverlay';
                overlay.innerHTML = modalHtml;
                document.body.appendChild(overlay);

                document.querySelectorAll('#globalThemeSelector .theme-option').forEach(el => {
                    el.addEventListener('click', () => {
                        document.querySelectorAll('#globalThemeSelector .theme-option').forEach(e => {
                            e.classList.remove('selected');
                            e.style.borderColor = 'transparent';
                        });
                        el.classList.add('selected');
                        el.style.borderColor = 'var(--primary)';
                    });
                });

                document.getElementById('saveGlobalConfigBtn').addEventListener('click', () => {
                    const theme = document.getElementById('globalThemeSelect').value;
                    const selected = document.querySelector('#globalThemeSelector .theme-option.selected');
                    const colorTheme = selected ? selected.dataset.theme : DEFAULT_GLOBAL_COLOR_THEME;
                    const gc = { theme, colorTheme };
                    saveGlobalConfig(gc);

                    const ownerPhone = document.getElementById('globalOwnerWhatsApp').value.trim();
                    if (ownerPhone) {
                        saveOwnerWhatsApp(ownerPhone);
                    }
                    alert('✅ Configurações globais salvas!');
                    document.getElementById('globalConfigOverlay').remove();
                    renderSuperAdminDashboard();
                });

                document.getElementById('closeGlobalConfigBtn').addEventListener('click', () => {
                    document.getElementById('globalConfigOverlay').remove();
                });
