            listHtml += `</div>`;
            superAdminContent.innerHTML = listHtml;

            document.querySelectorAll('[data-action="renew"]').forEach(btn => {
                btn.addEventListener('click', () => {
                    const phone = btn.dataset.phone;
                    const users = getUsers();
                    const idx = users.findIndex(u => u.phone === phone);
                    if (idx !== -1) {
                        const now = Date.now();
                        const currentExp = users[idx].expiresAt || (users[idx].createdAt + 30 * 24 * 60 * 60 * 1000);
                        const newExp = Math.max(currentExp, now) + 30 * 24 * 60 * 60 * 1000;
