        }

        document.getElementById('closeSuperAdmin').addEventListener('click', () => {
            superAdminOverlay.classList.remove('open');
        });
        superAdminOverlay.addEventListener('click', (e) => {
            if (e.target === superAdminOverlay) superAdminOverlay.classList.remove('open');
        });

        // ============================================================
        //  AUTENTICAÇÃO (CORRIGIDA)
        // ============================================================
        const authContainer = document.getElementById('authContainer');
        const appContainer = document.getElementById('appContainer');
        const loginForm = document.getElementById('loginForm');
        const registerForm = document.getElementById('registerForm');
        const loginPhone = document.getElementById('loginPhone');
        const loginPassword = document.getElementById('loginPassword');
        const loginBtn = document.getElementById('loginBtn');
        const loginError = document.getElementById('loginError');
        const registerName = document.getElementById('registerName');
        const registerPhone = document.getElementById('registerPhone');
        const registerPassword = document.getElementById('registerPassword');
        const registerConfirm = document.getElementById('registerConfirm');
        const registerBtn = document.getElementById('registerBtn');
        const registerError = document.getElementById('registerError');
        const registerSuccess = document.getElementById('registerSuccess');
        const showLogin = document.getElementById('showLogin');
        const backToRegister = document.getElementById('backToRegister');
        const logoutBtn = document.getElementById('logoutBtn');
        const settingsBtn = document.getElementById('openSettings');
        const refreshBtn = document.getElementById('refreshBtn');
        const gestaoBtn = document.getElementById('openGestao');
        const expirationBanner = document.getElementById('expirationBanner');
        const expirationText = document.getElementById('expirationText');

        // ============================================================
        //  FUNÇÃO DE ATUALIZAÇÃO (refresh)
        // ============================================================
        function refreshData() {
            if (!currentPhone) return;
            const config = getStudioConfig(currentPhone);
            appointments = getAppointments(currentPhone);
            applyStudioConfig(config);
            const loggedUser = JSON.parse(localStorage.getItem('loggedUser') || '{}');
            if (loggedUser.name) {
                document.getElementById('clientName').value = loggedUser.name;
            }
            if (loggedUser.phone) {
                document.getElementById('clientPhone').value = loggedUser.phone;
            }
            renderAll();
            const status = document.getElementById('formStatus');
            if (status) {
                status.textContent = '🔄 Dados atualizados!';
                status.className = 'status-msg';
                setTimeout(() => {
                    status.textContent = '';
                    status.className = 'status-msg';
                }, 2000);
            }
        }

        // ============================================================
        //  AUTENTICAÇÃO - CHECK SESSION
        // ============================================================
        function checkSession() {
            const logged = localStorage.getItem('loggedUser');
            if (logged) {
                const user = JSON.parse(logged);
                const users = getUsers();
                const found = users.find(u => u.phone === user.phone);
                if (!found) {
                    localStorage.removeItem('loggedUser');
                    showAuth();
                    return;
                }
                if (found.blocked) {
                    localStorage.removeItem('loggedUser');
                    loginError.textContent = '⛔ Este salão está bloqueado. Entre em contato com o administrador.';
                    loginError.style.display = 'block';
                    showAuth();
                    return;
                }
                const now = Date.now();
                const expires = found.expiresAt || (found.createdAt + 30 * 24 * 60 * 60 * 1000);
                if (now > expires) {
                    localStorage.removeItem('loggedUser');
                    loginError.textContent = '⛔ Seu plano expirou. Entre em contato com o administrador para renovar.';
                    loginError.style.display = 'block';
                    showAuth();
                    return;
                }
                showApp(found.admin || false);
            } else {
                showAuth();
            }
        }

        function showApp(isAdmin) {
            authContainer.style.display = 'none';
            appContainer.classList.add('active');
            const loggedUser = JSON.parse(localStorage.getItem('loggedUser') || '{}');
            if (!loggedUser.phone) return;
            currentPhone = loggedUser.phone;
            const c = getStudioConfig(currentPhone);
            applyStudioConfig(c);
            if (loggedUser.name) {
                document.getElementById('clientName').value = loggedUser.name;
            }
            if (loggedUser.phone) {
                document.getElementById('clientPhone').value = loggedUser.phone;
            }
            appointments = getAppointments(currentPhone);

            const adminView = document.getElementById('adminView');
            const clientView = document.getElementById('clientView');
            const quickTheme = document.getElementById('quickThemeSelector');
            const modeSelector = document.getElementById('modeSelector');

            if (isAdmin) {
                settingsBtn.classList.add('visible');
                refreshBtn.classList.add('visible');
                gestaoBtn.classList.add('visible');
                quickTheme.classList.add('visible');
                modeSelector.classList.add('visible');
                showAdminView();
            } else {
                settingsBtn.classList.remove('visible');
                refreshBtn.classList.remove('visible');
                gestaoBtn.classList.remove('visible');
                quickTheme.classList.remove('visible');
                modeSelector.classList.remove('visible');
                showClientView();
            }

            const users = getUsers();
            const found = users.find(u => u.phone === loggedUser.phone);
            if (found) {
                const now = Date.now();
                const expires = found.expiresAt || (found.createdAt + 30 * 24 * 60 * 60 * 1000);
                const daysLeft = Math.ceil((expires - now) / (24 * 60 * 60 * 1000));
                if (daysLeft <= 7) {
                    expirationBanner.style.display = 'block';
                    expirationText.textContent = `⚠️ Seu plano expira em ${daysLeft} dia${daysLeft > 1 ? 's' : ''}. Entre em contato com o administrador para renovar.`;
                } else {
                    expirationBanner.style.display = 'none';
                }
            }
        }

        function showAdminView() {
            document.getElementById('adminView').style.display = 'block';
            document.getElementById('clientView').style.display = 'none';
            renderAdminAppointments();
        }

        function showClientView() {
            document.getElementById('adminView').style.display = 'none';
            document.getElementById('clientView').style.display = 'block';
            loadClientAppointments();
            renderClientCalendar();
            renderClientHours();
            updateSelectedDateTime();
        }

        function showAuth() {
            authContainer.style.display = 'block';
            appContainer.classList.remove('active');
            registerForm.classList.remove('hidden');
            loginForm.classList.add('hidden');
            loginError.textContent = '';
            registerError.textContent = '';
            registerSuccess.textContent = '';
            settingsBtn.classList.remove('visible');
            refreshBtn.classList.remove('visible');
            gestaoBtn.classList.remove('visible');
            document.getElementById('quickThemeSelector').classList.remove('visible');
            document.getElementById('modeSelector').classList.remove('visible');
            expirationBanner.style.display = 'none';
        }

        // ============================================================
        //  REGISTER
        // ============================================================
        registerBtn.addEventListener('click', () => {
            const name = registerName.value.trim();
            const phone = registerPhone.value.trim();
            const password = registerPassword.value.trim();
            const confirm = registerConfirm.value.trim();
            registerError.textContent = '';
            registerSuccess.textContent = '';
            if (!name || !phone || !password || !confirm) {
                registerError.textContent = 'Preencha todos os campos.';
                return;
            }
            if (password.length < 4) {
                registerError.textContent = 'A senha deve ter pelo menos 4 caracteres.';
                return;
            }
            if (password !== confirm) {
                registerError.textContent = 'As senhas não coincidem.';
                return;
            }
            const users = getUsers();
            if (users.find(u => u.phone === phone)) {
                registerError.textContent = 'Este telefone já está cadastrado.';
                return;
            }
            const now = Date.now();
            const isAdmin = users.length === 1; // admin padrão já existe
            const gc = getGlobalConfig();
            const defaultTheme = gc.colorTheme || DEFAULT_GLOBAL_COLOR_THEME;
            const defaultColors = COLOR_THEMES[defaultTheme]?.colors || COLOR_THEMES.azul_claro.colors;

            users.push({
                name,
                phone,
                password,
                admin: isAdmin,
                createdAt: now,
                expiresAt: now + 30 * 24 * 60 * 60 * 1000,
                blocked: false
            });
            saveUsers(users);

            const defConfig = {
                name: name,
                phone: phone,
                profileImage: null,
                logoImage: null,
                availableHours: ['09:00','10:00','11:00','12:00','13:00','14:00','15:00','16:00','17:00','18:00','19:00'],
                colorTheme: defaultTheme,
                colors: { ...defaultColors },
                categories: ['Corte', 'Coloração', 'Escova', 'Progressiva', 'Penteado', 'Outro']
            };
            saveStudioConfig(phone, defConfig);
            saveAppointments(phone, []);
            saveTransacoes(phone, []);

            registerSuccess.textContent = '✅ Conta criada! Faça login.';
            registerName.value = '';
            registerPhone.value = '';
            registerPassword.value = '';
            registerConfirm.value = '';
            setTimeout(() => {
                registerForm.classList.add('hidden');
                loginForm.classList.remove('hidden');
                registerSuccess.textContent = '';
                loginError.textContent = '';
            }, 1500);
        });

        // ============================================================
        //  LOGIN (CORRIGIDO)
        // ============================================================
        loginBtn.addEventListener('click', function() {
            const phone = loginPhone.value.trim();
            const password = loginPassword.value.trim();
            loginError.textContent = '';

            if (!phone || !password) {
                loginError.textContent = 'Preencha telefone e senha.';
                return;
            }

            // Busca usuários, garantindo que o admin padrão exista
            const users = getUsers();
            const user = users.find(u => u.phone === phone && u.password === password);

            if (!user) {
                loginError.textContent = 'Telefone ou senha inválidos.';
                return;
            }

            if (user.blocked) {
                loginError.textContent = '⛔ Este salão está bloqueado. Entre em contato com o administrador.';
                return;
            }

            const now = Date.now();
            const expires = user.expiresAt || (user.createdAt + 30 * 24 * 60 * 60 * 1000);
            if (now > expires) {
                loginError.textContent = '⛔ Seu plano expirou. Entre em contato com o administrador para renovar.';
                return;
            }

            // Sucesso: salva sessão
            localStorage.setItem('loggedUser', JSON.stringify({
                name: user.name,
                phone: user.phone,
                admin: user.admin || false
            }));

            loginPhone.value = '';
            loginPassword.value = '';
            loginError.textContent = '';

            // Redireciona para o app
            showApp(user.admin || false);
        });

        // ============================================================
        //  LOGOUT
        // ============================================================
        logoutBtn.addEventListener('click', () => {
            localStorage.removeItem('loggedUser');
            showAuth();
        });

        // ============================================================
        //  MOSTRAR/OCULTAR FORMS
        // ============================================================
        showLogin.addEventListener('click', () => {
            registerForm.classList.add('hidden');
            loginForm.classList.remove('hidden');
            loginError.textContent = '';
            registerError.textContent = '';
            registerSuccess.textContent = '';
        });

        backToRegister.addEventListener('click', () => {
            loginForm.classList.add('hidden');
            registerForm.classList.remove('hidden');
            loginError.textContent = '';
            registerError.textContent = '';
            registerSuccess.textContent = '';
        });

        // ============================================================
        //  ENTER KEY
        // ============================================================
        document.querySelectorAll('#registerName, #registerPhone, #registerPassword, #registerConfirm').forEach(i => {
            i.addEventListener('keypress', e => { if (e.key === 'Enter') registerBtn.click(); });
        });
        document.querySelectorAll('#loginPhone, #loginPassword').forEach(i => {
            i.addEventListener('keypress', e => { if (e.key === 'Enter') loginBtn.click(); });
        });

        // ============================================================
        //  SELETOR DE MODO
        // ============================================================
        document.querySelectorAll('#modeSelector button').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('#modeSelector button').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                if (btn.dataset.mode === 'admin') {
                    showAdminView();
                } else {
                    showClientView();
                }
            });
        });

        // ============================================================
        //  QUICK THEME
        // ============================================================
        document.querySelectorAll('#quickThemeSelector button').forEach(btn => {
            btn.addEventListener('click', () => {
                const theme = btn.dataset.theme;
                applyTheme(theme);
                document.getElementById('themeSelect').value = theme;
            });
        });

        // ============================================================
        //  CLIENTE: CALENDÁRIO E AGENDAMENTO
        // ============================================================
        let clientAppointments = [];
        let currentDate = new Date();
        let selectedDate = new Date(); selectedDate.setHours(0,0,0,0);
        let selectedHour = null;

        const monthYearEl = document.getElementById('monthYear');
        const daysGrid = document.getElementById('daysGrid');
        const hoursGrid = document.getElementById('hoursGrid');
        const prevMonthBtn = document.getElementById('prevMonth');
        const nextMonthBtn = document.getElementById('nextMonth');
        const selectedDateTime = document.getElementById('selectedDateTime');
        const form = document.getElementById('appointmentForm');
        const formStatus = document.getElementById('formStatus');
        const clientAppointmentsContainer = document.getElementById('clientAppointmentsContainer');

        function loadClientAppointments() {
            const loggedUser = JSON.parse(localStorage.getItem('loggedUser') || '{}');
            const userPhone = loggedUser.phone;
            const all = getAppointments(currentPhone);
            clientAppointments = all.filter(a => a.phone === userPhone);
            renderClientAppointments();
        }

        function renderClientAppointments() {
            if (clientAppointments.length === 0) {
                clientAppointmentsContainer.innerHTML = `<p class="no-appointments">Nenhum agendamento ainda.</p>`;
                return;
            }
            const sorted = [...clientAppointments].sort((a,b) => a.date.localeCompare(b.date) || a.hour.localeCompare(b.hour));
            let html = '';
            sorted.forEach((app) => {
                const d = parseDateKey(app.date).toLocaleDateString('pt-BR', { timeZone:'UTC' });
                const statusClass = app.status === 'confirmado' ? 'confirmed' : 'pending';
                const statusText = app.status === 'confirmado' ? '✅ Confirmado' : '⏳ Pendente';
                html += `
                    <div class="appointment-item">
                        <div class="appointment-info">
                            <span><strong>${app.client}</strong></span>
                            <span>✂️ ${app.service}</span>
                            <span>📅 ${d} às ${app.hour}</span>
                            <span class="appointment-status ${statusClass}">${statusText}</span>
                        </div>
                    </div>
                `;
            });
            clientAppointmentsContainer.innerHTML = html;
        }

        function formatDateKey(d) {
            const y = d.getFullYear(), m = String(d.getMonth()+1).padStart(2,'0'), day = String(d.getDate()).padStart(2,'0');
            return `${y}-${m}-${day}`;
        }
        function parseDateKey(k) { const [y,m,d] = k.split('-').map(Number); return new Date(y,m-1,d); }
        function getClientAppForDate(k) { return clientAppointments.filter(a => a.date === k); }
        function isBooked(k, h) { return clientAppointments.some(a => a.date === k && a.hour === h); }

        function getActiveHours() {
            if (!currentPhone) return ['09:00','10:00','11:00','12:00','13:00','14:00','15:00','16:00','17:00','18:00','19:00'];
            const config = getStudioConfig(currentPhone);
            return config.availableHours || ['09:00','10:00','11:00','12:00','13:00','14:00','15:00','16:00','17:00','18:00','19:00'];
        }

        function renderClientCalendar() {
            const year = currentDate.getFullYear(), month = currentDate.getMonth();
            const first = new Date(year,month,1).getDay(), days = new Date(year,month+1,0).getDate();
            const today = new Date(); today.setHours(0,0,0,0);
            monthYearEl.textContent = new Intl.DateTimeFormat('pt-BR', { month:'long', year:'numeric' }).format(currentDate);
            const prevDays = new Date(year,month,0).getDate();
            let html = '';
            for (let i = first-1; i>=0; i--) { html += `<div class="day-cell other-month">${prevDays - i}</div>`; }
            for (let d=1; d<=days; d++) {
                const dateObj = new Date(year,month,d);
                const key = formatDateKey(dateObj);
                const isToday = dateObj.getTime() === today.getTime();
                const isSelected = dateObj.getTime() === selectedDate.getTime();
                const hasApp = getClientAppForDate(key).length > 0;
                let cls = 'day-cell';
                if (isToday) cls += ' today';
                if (isSelected) cls += ' selected';
                if (hasApp) cls += ' has-appointment';
                html += `<div class="${cls}" data-date="${key}">${d}</div>`;
            }
            daysGrid.innerHTML = html;
            document.querySelectorAll('.day-cell:not(.other-month)').forEach(el => {
                el.addEventListener('click', () => {
                    const [y,m,d] = el.dataset.date.split('-').map(Number);
                    selectedDate = new Date(y,m-1,d);
                    selectedHour = null;
                    renderClientHours();
                    updateSelectedDateTime();
                });
            });
        }

        function renderClientHours() {
            const key = formatDateKey(selectedDate);
            const booked = clientAppointments.filter(a => a.date === key).map(a => a.hour);
            const activeHours = getActiveHours();
            let html = '';
            if (activeHours.length === 0) {
                html = '<p style="color:var(--text-muted);text-align:center;padding:12px;">Nenhum horário disponível.</p>';
            } else {
                activeHours.forEach(h => {
                    const b = booked.includes(h);
                    const sel = selectedHour === h && !b;
                    let cls = 'hour-btn';
                    if (b) cls += ' booked';
                    if (sel) cls += ' selected-hour';
                    html += `<button class="${cls}" data-hour="${h}" ${b ? 'disabled' : ''}>${h}</button>`;
                });
            }
            hoursGrid.innerHTML = html;
            document.querySelectorAll('.hour-btn:not(.booked)').forEach(btn => {
                btn.addEventListener('click', () => { selectedHour = btn.dataset.hour; renderClientHours(); updateSelectedDateTime(); });
            });
            updateSelectedDateTime();
        }

        function updateSelectedDateTime() {
            const ds = selectedDate.toLocaleDateString('pt-BR', { timeZone:'UTC' });
            selectedDateTime.value = `${ds} às ${selectedHour || '—'}`;
        }

        prevMonthBtn.addEventListener('click', () => {
            currentDate.setMonth(currentDate.getMonth() - 1);
            const d = selectedDate.getDate();
            const nd = new Date(currentDate.getFullYear(), currentDate.getMonth(), d);
            if (nd.getMonth() === currentDate.getMonth()) selectedDate = nd;
            else { const last = new Date(currentDate.getFullYear(), currentDate.getMonth()+1, 0).getDate(); selectedDate = new Date(currentDate.getFullYear(), currentDate.getMonth(), Math.min(d,last)); }
            renderClientCalendar();
            renderClientHours();
            updateSelectedDateTime();
        });

        nextMonthBtn.addEventListener('click', () => {
            currentDate.setMonth(currentDate.getMonth() + 1);
            const d = selectedDate.getDate();
            const nd = new Date(currentDate.getFullYear(), currentDate.getMonth(), d);
            if (nd.getMonth() === currentDate.getMonth()) selectedDate = nd;
            else { const last = new Date(currentDate.getFullYear(), currentDate.getMonth()+1, 0).getDate(); selectedDate = new Date(currentDate.getFullYear(), currentDate.getMonth(), Math.min(d,last)); }
            renderClientCalendar();
            renderClientHours();
            updateSelectedDateTime();
        });

        form.addEventListener('submit', (e) => {
            e.preventDefault();
            const client = document.getElementById('clientName').value.trim();
            const phone = document.getElementById('clientPhone').value.trim();
            const service = document.getElementById('service').value;
            const key = formatDateKey(selectedDate);
            const hour = selectedHour;
            if (!client || !phone) {
                formStatus.textContent = 'Preencha nome e telefone.';
                formStatus.className = 'status-msg error';
                return;
            }
            if (!hour) {
                formStatus.textContent = 'Selecione um horário disponível.';
                formStatus.className = 'status-msg error';
                return;
            }
            if (!service) {
                formStatus.textContent = 'Selecione um serviço.';
                formStatus.className = 'status-msg error';
                return;
            }
            if (isBooked(key, hour)) {
                formStatus.textContent = 'Este horário já foi reservado.';
                formStatus.className = 'status-msg error';
                renderClientCalendar();
                renderClientHours();
                return;
            }

            const d = parseDateKey(key);
            const dateStr = d.toLocaleDateString('pt-BR', { timeZone: 'UTC' });

            const adminPhone = window.STUDIO_PHONE || null;
            if (!adminPhone) {
                formStatus.textContent = '⚠️ O administrador não configurou o WhatsApp.';
                formStatus.className = 'status-msg error';
                return;
            }

            const newApp = {
                client,
                phone,
                service,
                date: key,
                hour,
                status: 'pendente',
                valor: 0,
                createdAt: new Date().toISOString()
            };
            const all = getAppointments(currentPhone);
            all.push(newApp);
            saveAppointments(currentPhone, all);
            clientAppointments.push(newApp);
            renderClientAppointments();

            selectedHour = null;
            document.getElementById('clientName').value = '';
            document.getElementById('clientPhone').value = '';
            formStatus.textContent = '✅ Agendamento realizado! Redirecionando para WhatsApp...';
            formStatus.className = 'status-msg';

            const msg = `*Novo agendamento!*%0A%0A` +
                        `👤 Cliente: ${client}%0A` +
                        `📞 Telefone: ${phone}%0A` +
                        `✂️ Serviço: ${service}%0A` +
                        `📅 Data: ${dateStr}%0A` +
                        `🕒 Horário: ${hour}%0A%0A` +
                        `Enviado automaticamente pelo sistema de agendamento.`;

            const url = `https://wa.me/${adminPhone}?text=${msg}`;
            window.open(url, '_blank');

            renderClientCalendar();
            renderClientHours();
            updateSelectedDateTime();
        });

        // ============================================================
        //  ADMIN: LISTA DE AGENDAMENTOS COM VALOR
        // ============================================================
        const adminContainer = document.getElementById('appointmentsContainer');
        const pendingBadge = document.getElementById('pendingBadge');
        const alertBox = document.getElementById('alertBox');
        const alertCount = document.getElementById('alertCount');

        function renderAdminAppointments() {
            const apps = getAppointments(currentPhone);
            const pendingCount = apps.filter(a => a.status === 'pendente').length;

            pendingBadge.textContent = `${pendingCount} pendente${pendingCount !== 1 ? 's' : ''}`;
            if (pendingCount > 0) {
                alertBox.style.display = 'block';
                alertCount.textContent = pendingCount;
            } else {
                alertBox.style.display = 'none';
            }

            if (apps.length === 0) {
                adminContainer.innerHTML = `<p class="no-appointments">Nenhum agendamento ainda.</p>`;
                return;
            }
            const sorted = [...apps].sort((a,b) => a.date.localeCompare(b.date) || a.hour.localeCompare(b.hour));
            let html = '';
            sorted.forEach((app, idx) => {
                const d = parseDateKey(app.date).toLocaleDateString('pt-BR', { timeZone:'UTC' });
                const statusClass = app.status === 'confirmado' ? 'confirmed' : 'pending';
                const statusText = app.status === 'confirmado' ? '✅ Confirmado' : '⏳ Pendente';
                const itemClass = app.status === 'confirmado' ? 'confirmed' : 'pending';

                const clientPhone = app.phone.replace(/\D/g, '');
                const whatsMsg = `Olá! Seu agendamento no Estúdio Claudineia foi ${app.status === 'confirmado' ? 'confirmado' : 'criado'}.%0A%0A📅 Data: ${d}%0A🕒 Horário: ${app.hour}%0A✂️ Serviço: ${app.service}`;
                const whatsUrl = `https://wa.me/55${clientPhone}?text=${whatsMsg}`;

                html += `
                    <div class="appointment-item ${itemClass}">
                        <div class="appointment-info">
                            <span><strong>${app.client}</strong></span>
                            <span>📞 ${app.phone}</span>
                            <span>✂️ ${app.service}</span>
                            <span>📅 ${d} às ${app.hour}</span>
                            <span class="appointment-status ${statusClass}">${statusText}</span>
                            <span style="font-weight:600; color:var(--primary);">💰 R$ ${app.valor ? parseFloat(app.valor).toFixed(2) : '0,00'}</span>
                        </div>
                        <div style="display:flex; gap:6px; flex-wrap:wrap;">
                            ${app.status === 'pendente' ? `<button class="btn-success" data-idx="${idx}" data-action="confirm">✅ Confirmar</button>` : ''}
                            <button class="btn-value" data-idx="${idx}" data-action="valor">💰 Valor</button>
                            <a href="${whatsUrl}" target="_blank" class="btn-whatsapp-small">📤 WhatsApp</a>
                            <button class="btn-danger" data-idx="${idx}" data-action="delete">🗑️ Excluir</button>
                        </div>
                    </div>
                `;
            });
            adminContainer.innerHTML = html;

            document.querySelectorAll('[data-action="confirm"]').forEach(btn => {
                btn.addEventListener('click', () => {
                    const idx = parseInt(btn.dataset.idx);
                    const apps = getAppointments(currentPhone);
                    if (apps[idx]) {
                        apps[idx].status = 'confirmado';
                        saveAppointments(currentPhone, apps);
                        renderAdminAppointments();
                        atualizarGestao();
                    }
                });
            });

            document.querySelectorAll('[data-action="valor"]').forEach(btn => {
                btn.addEventListener('click', () => {
                    const idx = parseInt(btn.dataset.idx);
                    const apps = getAppointments(currentPhone);
                    if (apps[idx]) {
                        const valorAtual = apps[idx].valor || 0;
                        const novoValor = prompt('Digite o valor do serviço (R$):', valorAtual.toFixed(2).replace('.', ','));
                        if (novoValor !== null) {
                            const val = parseFloat(novoValor.replace(',', '.'));
                            if (!isNaN(val) && val >= 0) {
                                apps[idx].valor = val;
                                saveAppointments(currentPhone, apps);
                                renderAdminAppointments();
                                atualizarGestao();
                            } else {
                                alert('Valor inválido. Use números.');
                            }
                        }
                    }
                });
            });

            document.querySelectorAll('[data-action="delete"]').forEach(btn => {
                btn.addEventListener('click', () => {
                    const idx = parseInt(btn.dataset.idx);
                    if (confirm('Tem certeza que deseja excluir este agendamento?')) {
                        const apps = getAppointments(currentPhone);
                        apps.splice(idx, 1);
                        saveAppointments(currentPhone, apps);
                        renderAdminAppointments();
                        atualizarGestao();
                    }
                });
            });
        }

        // ============================================================
        //  GESTÃO (Vendas, Entradas, Saídas, Relatórios)
        // ============================================================
        const gestaoOverlay = document.getElementById('gestaoOverlay');
        const gestaoContent = document.getElementById('gestaoContent');

        document.getElementById('openGestao').addEventListener('click', () => {
            gestaoOverlay.classList.add('open');
            atualizarGestao();
        });

        document.getElementById('closeGestao').addEventListener('click', () => {
            gestaoOverlay.classList.remove('open');
        });
        gestaoOverlay.addEventListener('click', (e) => {
            if (e.target === gestaoOverlay) gestaoOverlay.classList.remove('open');
        });

        // Tabs
        document.querySelectorAll('.gestao-tabs button').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.gestao-tabs button').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                const tab = btn.dataset.tab;
                document.querySelectorAll('.gestao-content .tab-pane').forEach(p => p.classList.remove('active'));
                document.getElementById('tab' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('active');
                atualizarGestao();
            });
        });

        function atualizarGestao() {
            if (!currentPhone) return;
            // Vendas
            const apps = getAppointments(currentPhone);
            const vendas = apps.filter(a => a.status === 'confirmado' && a.valor > 0);
            const totalVendas = vendas.reduce((s, a) => s + a.valor, 0);
            document.getElementById('totalVendasValor').textContent = `R$ ${totalVendas.toFixed(2).replace('.', ',')}`;
            document.getElementById('totalVendasQtd').textContent = vendas.length;
            const listaVendas = document.getElementById('listaVendas');
            if (vendas.length === 0) {
                listaVendas.innerHTML = `<p class="no-appointments">Nenhuma venda registrada.</p>`;
            } else {
                let html = '';
                vendas.forEach(v => {
                    const d = parseDateKey(v.date).toLocaleDateString('pt-BR');
                    html += `
                        <div class="transacao-item">
                            <div class="info">
                                <span><strong>${v.client}</strong></span>
                                <span>${v.service}</span>
                                <span>📅 ${d} ${v.hour}</span>
                                <span class="valor">R$ ${v.valor.toFixed(2).replace('.', ',')}</span>
                            </div>
                        </div>
                    `;
                });
                listaVendas.innerHTML = html;
            }

            // Entradas e Saídas
            const transacoes = getTransacoes(currentPhone);
            const entradas = transacoes.filter(t => t.tipo === 'entrada');
            const saidas = transacoes.filter(t => t.tipo === 'saida');
            renderTransacoes('entradas', entradas);
            renderTransacoes('saidas', saidas);

            // Relatórios
            const mes = document.getElementById('relMes').value;
            let totalEntradas = 0, totalSaidas = 0;
            let filtroEntradas = entradas, filtroSaidas = saidas;
            let totalVendasMes = 0;
            if (mes) {
                const [ano, mesNum] = mes.split('-').map(Number);
                filtroEntradas = entradas.filter(t => {
                    const d = new Date(t.data);
                    return d.getFullYear() === ano && d.getMonth() === mesNum - 1;
                });
                filtroSaidas = saidas.filter(t => {
                    const d = new Date(t.data);
                    return d.getFullYear() === ano && d.getMonth() === mesNum - 1;
                });
                const vendasMes = vendas.filter(v => {
                    const d = parseDateKey(v.date);
                    return d.getFullYear() === ano && d.getMonth() === mesNum - 1;
                });
                totalVendasMes = vendasMes.reduce((s, v) => s + v.valor, 0);
            }
            totalEntradas = filtroEntradas.reduce((s, t) => s + t.valor, 0);
            totalSaidas = filtroSaidas.reduce((s, t) => s + t.valor, 0);
            document.getElementById('relVendas').textContent = `R$ ${totalVendasMes.toFixed(2).replace('.', ',')}`;
            document.getElementById('relEntradas').textContent = `R$ ${totalEntradas.toFixed(2).replace('.', ',')}`;
            document.getElementById('relSaidas').textContent = `R$ ${totalSaidas.toFixed(2).replace('.', ',')}`;
            const saldo = totalVendasMes + totalEntradas - totalSaidas;
            document.getElementById('relSaldo').textContent = `R$ ${saldo.toFixed(2).replace('.', ',')}`;
            document.getElementById('relSaldo').className = 'value ' + (saldo >= 0 ? 'positive' : 'negative');
        }

        function renderTransacoes(tipo, lista) {
            const container = document.getElementById('lista' + tipo.charAt(0).toUpperCase() + tipo.slice(1));
            if (lista.length === 0) {
                container.innerHTML = `<p class="no-appointments">Nenhuma ${tipo} registrada.</p>`;
                return;
            }
            const sorted = [...lista].sort((a,b) => new Date(b.data) - new Date(a.data));
            let html = '';
            sorted.forEach(t => {
                const d = new Date(t.data).toLocaleDateString('pt-BR');
                html += `
                    <div class="transacao-item">
                        <div class="info">
                            <span><strong>${t.descricao}</strong></span>
                            <span>📅 ${d}</span>
                            <span class="valor">R$ ${t.valor.toFixed(2).replace('.', ',')}</span>
                            <span class="tipo ${tipo}">${tipo === 'entrada' ? '⬆️ Entrada' : '⬇️ Saída'}</span>
                        </div>
                        <button class="btn-danger" data-tipo="${tipo}" data-id="${t.id}" style="padding:4px 12px; font-size:0.75rem;">✕</button>
                    </div>
                `;
            });
            container.innerHTML = html;
            container.querySelectorAll('.btn-danger').forEach(btn => {
                btn.addEventListener('click', () => {
                    const id = btn.dataset.id;
                    const tipo = btn.dataset.tipo;
                    let transacoes = getTransacoes(currentPhone);
                    transacoes = transacoes.filter(t => t.id !== id);
                    saveTransacoes(currentPhone, transacoes);
                    atualizarGestao();
                });
            });
        }

        document.getElementById('addEntradaBtn').addEventListener('click', () => {
            const desc = document.getElementById('entradaDesc').value.trim();
            const valor = parseFloat(document.getElementById('entradaValor').value.replace(',', '.'));
            const data = document.getElementById('entradaData').value;
            if (!desc || isNaN(valor) || valor <= 0 || !data) {
                alert('Preencha todos os campos corretamente.');
                return;
            }
            const transacoes = getTransacoes(currentPhone);
            transacoes.push({
                id: Date.now() + '_' + Math.random().toString(36).substr(2, 4),
                tipo: 'entrada',
                descricao: desc,
                valor: valor,
                data: data
            });
            saveTransacoes(currentPhone, transacoes);
            document.getElementById('entradaDesc').value = '';
            document.getElementById('entradaValor').value = '';
            document.getElementById('entradaData').value = '';
            atualizarGestao();
        });

        document.getElementById('addSaidaBtn').addEventListener('click', () => {
            const desc = document.getElementById('saidaDesc').value.trim();
            const valor = parseFloat(document.getElementById('saidaValor').value.replace(',', '.'));
            const data = document.getElementById('saidaData').value;
            if (!desc || isNaN(valor) || valor <= 0 || !data) {
                alert('Preencha todos os campos corretamente.');
                return;
            }
            const transacoes = getTransacoes(currentPhone);
            transacoes.push({
                id: Date.now() + '_' + Math.random().toString(36).substr(2, 4),
                tipo: 'saida',
                descricao: desc,
                valor: valor,
                data: data
            });
            saveTransacoes(currentPhone, transacoes);
            document.getElementById('saidaDesc').value = '';
            document.getElementById('saidaValor').value = '';
            document.getElementById('saidaData').value = '';
            atualizarGestao();
        });

        document.getElementById('atualizarRelatorio').addEventListener('click', atualizarGestao);

        document.addEventListener('DOMContentLoaded', () => {
            const hoje = new Date().toISOString().split('T')[0];
            document.getElementById('entradaData').value = hoje;
            document.getElementById('saidaData').value = hoje;
            document.getElementById('relMes').value = hoje.substring(0, 7);
        });

        // ============================================================
        //  INIT
        // ============================================================
        const today = new Date(); today.setHours(0,0,0,0);
        selectedDate = today;
        currentDate = new Date(today);
        loadThemeRes();
        checkSession();

        let resizeTimer;
        window.addEventListener('resize', () => {
            clearTimeout(resizeTimer);
            resizeTimer = setTimeout(() => {
                if (document.getElementById('resolutionSelect').value === 'auto') {
                    document.documentElement.removeAttribute('data-resolution');
                }
            }, 200);
        });
    </script>
</body>
</html>
