    <script>
        // ================================================================
        //   DADOS GLOBAIS
        // ================================================================
        let produtos = [];
        let carrinho = [];
        let dadosBanco = { banco: '', agencia: '', conta: '', pix: '', titular: '' };
        let impressoraConfig = { tipo: 'bluetooth', nome: '', endereco: '', senha: '' };
        let ordemAtual = 'nome';
        let fotoCriacaoBase64 = null,
            fotoEdicaoBase64 = null;
        let produtoEditandoId = null,
            produtoParaAdicionar = null;
        let pagamentoSelecionado = null;
        let comprovanteGerado = '';
        let ultimoTotal = 0;
        let tipoEnvio = '';
        let numeroPedido = 1;
        let zoomAtual = 150;
        let quantidadeSelecionada = 1;

        // Variações globais: array de objetos { id, nome, ativo, min, max, opcoes: [{nome, preco}] }
        let variacoesGlobais = [];

        let deviceListVisible = false;
        let bluetoothDevice = null;

        // Para edição de variação global
        let variacaoEditandoId = null;

        // ================================================================
        //   ZOOM
        // ================================================================
        function aplicarZoom() {
            document.body.style.zoom = zoomAtual + '%';
            try { localStorage.setItem('zoomNivel', zoomAtual); } catch (e) {}
        }

        function salvarZoom() {
            zoomAtual = parseInt(document.getElementById('zoomNivel').value);
            aplicarZoom();
            alert(`Zoom ajustado para ${zoomAtual}%`);
        }

        function carregarZoom() {
            try {
                const salvo = localStorage.getItem('zoomNivel');
                if (salvo) zoomAtual = parseInt(salvo);
                else if (window.innerWidth <= 768) zoomAtual = 150;
                else if (window.innerWidth <= 1024) zoomAtual = 130;
                else zoomAtual = 100;
            } catch (e) { zoomAtual = 100; }
            aplicarZoom();
        }

        // ================================================================
        //   PERSISTÊNCIA
        // ================================================================
        function salvarProdutos() { try { localStorage.setItem('produtos', JSON.stringify(produtos)); } catch (e) { console.warn('Erro ao salvar produtos', e); } }

        function salvarCarrinho() { try { localStorage.setItem('carrinho', JSON.stringify(carrinho)); } catch (e) { console.warn('Erro ao salvar carrinho', e); } }

        function salvarBanco() { try { localStorage.setItem('dadosBanco', JSON.stringify(dadosBanco)); } catch (e) { console.warn('Erro ao salvar banco', e); } }

        function salvarImpressora() { try { localStorage.setItem('impressoraConfig', JSON.stringify(impressoraConfig)); } catch (e) { console.warn('Erro ao salvar impressora', e); } }

        function salvarNumeroPedido() { try { localStorage.setItem('numeroPedido', numeroPedido); } catch (e) { console.warn('Erro ao salvar número do pedido', e); } }

        function salvarVariacoesGlobais() { try { localStorage.setItem('variacoesGlobais', JSON.stringify(variacoesGlobais)); } catch (e) { console.warn('Erro ao salvar variações globais', e); } }

        function carregarDados() {
            try {
                const prodSalvos = localStorage.getItem('produtos');
                const carrSalvo = localStorage.getItem('carrinho');
                const bancoSalvo = localStorage.getItem('dadosBanco');
                const impressoraSalva = localStorage.getItem('impressoraConfig');
                const numPedidoSalvo = localStorage.getItem('numeroPedido');
                const varGlobais = localStorage.getItem('variacoesGlobais');

                if (numPedidoSalvo) numeroPedido = parseInt(numPedidoSalvo);
                if (prodSalvos) produtos = JSON.parse(prodSalvos);
                else produtos = [
                    { id: 1, nome: "Açaí Pequeno", preco: 18.90, foto: null, grupos: [] },
                    { id: 2, nome: "Açaí Médio", preco: 24.90, foto: null, grupos: [] },
                    { id: 3, nome: "Tapioca de Queijo", preco: 14.90, foto: null, grupos: [] }
                ];
                if (carrSalvo) carrinho = JSON.parse(carrSalvo);
                if (bancoSalvo) dadosBanco = JSON.parse(bancoSalvo);
                if (impressoraSalva) impressoraConfig = JSON.parse(impressoraSalva);
                if (varGlobais) variacoesGlobais = JSON.parse(varGlobais);
                else {
                    // Cria algumas variações de exemplo
                    variacoesGlobais = [{
                        id: 1,
                        nome: "Tamanho",
                        ativo: true,
                        min: 1,
                        max: 1,
                        opcoes: [
                            { nome: "Pequeno", preco: 0 },
                            { nome: "Médio", preco: 2.00 },
                            { nome: "Grande", preco: 4.00 }
                        ]
                    }, {
                        id: 2,
                        nome: "Adicionais",
                        ativo: true,
                        min: 0,
                        max: 3,
                        opcoes: [
                            { nome: "Leite Condensado", preco: 1.50 },
                            { nome: "Granola", preco: 1.00 },
                            { nome: "Morango", preco: 2.00 },
                            { nome: "Banana", preco: 1.50 }
                        ]
                    }];
                    salvarVariacoesGlobais();
                }
            } catch (e) {
                console.warn('Erro ao carregar dados, usando defaults', e);
                produtos = [
                    { id: 1, nome: "Açaí Pequeno", preco: 18.90, foto: null, grupos: [] },
                    { id: 2, nome: "Açaí Médio", preco: 24.90, foto: null, grupos: [] },
                    { id: 3, nome: "Tapioca de Queijo", preco: 14.90, foto: null, grupos: [] }
                ];
                carrinho = [];
                if (!variacoesGlobais.length) {
                    variacoesGlobais = [{
                        id: 1,
                        nome: "Tamanho",
                        ativo: true,
                        min: 1,
                        max: 1,
                        opcoes: [
                            { nome: "Pequeno", preco: 0 },
                            { nome: "Médio", preco: 2.00 },
                            { nome: "Grande", preco: 4.00 }
                        ]
                    }, {
                        id: 2,
                        nome: "Adicionais",
                        ativo: true,
                        min: 0,
                        max: 3,
                        opcoes: [
                            { nome: "Leite Condensado", preco: 1.50 },
                            { nome: "Granola", preco: 1.00 },
                            { nome: "Morango", preco: 2.00 },
                            { nome: "Banana", preco: 1.50 }
                        ]
                    }];
                    salvarVariacoesGlobais();
                }
            }
            if (!dadosBanco.pix) dadosBanco.pix = "chave@exemplo.com";
            if (!impressoraConfig.tipo) impressoraConfig.tipo = 'bluetooth';
            atualizarCamposImpressora();
        }

        // ================================================================
        //   CAMPOS CONFIG
        // ================================================================
        function atualizarCamposImpressora() {
            const tipo = impressoraConfig.tipo || 'bluetooth';
            document.getElementById('impressoraTipo').value = tipo;
            toggleImpressoraSections(tipo);

            if (tipo === 'bluetooth') {
                const nome = impressoraConfig.nome || 'Nenhum dispositivo conectado';
                document.getElementById('bluetoothStatus').innerHTML = `🔗 ${nome}`;
            } else {
                document.getElementById('impressoraNomeRede').value = impressoraConfig.nome || '';
                document.getElementById('impressoraEnderecoRede').value = impressoraConfig.endereco || '';
                document.getElementById('impressoraSenhaRede').value = impressoraConfig.senha || '';
            }
            document.getElementById('previewImpressora').innerHTML = impressoraConfig.nome ?
                `🖨️ ${impressoraConfig.nome} (${tipo})` :
                'Nenhuma impressora configurada';
        }

        function toggleImpressoraSections(tipo) {
            const bluetoothSection = document.getElementById('bluetoothSection');
            const redeSection = document.getElementById('redeSection');
            if (tipo === 'bluetooth') {
                bluetoothSection.style.display = 'block';
