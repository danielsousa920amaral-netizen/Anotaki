        // ================================================================
        //   CARRINHO E VARIAÇÕES (usando globais)
        // ================================================================
        function iniciarAdicaoComVariacoes(produto) {
            // Pega os grupos ativos do produto (referências)
            const gruposRef = (produto.grupos || []).filter(g => g.ativo);
            const gruposAtivos = [];
            gruposRef.forEach(ref => {
                const v = variacoesGlobais.find(v => v.id === ref.id);
                if (v && v.ativo && v.opcoes.length) {
                    gruposAtivos.push({
                        id: v.id,
                        nome: v.nome,
                        ativo: true,
                        min: ref.min !== undefined ? ref.min : v.min,
                        max: ref.max !== undefined ? ref.max : v.max,
                        opcoes: v.opcoes // opções da variação global
                    });
                }
            });

            produtoParaAdicionar = produto;
            const container = document.getElementById('gruposEscolhaContainer');
            container.innerHTML = '';
            document.getElementById('erroVariacao').innerHTML = '';

            if (gruposAtivos.length === 0) {
                container.innerHTML =
                    '<div class="grupo-variacao" style="text-align:center; padding:1rem;">Este produto não tem variações ativas.<br>Defina a quantidade desejada.</div>';
            } else {
                gruposAtivos.forEach((grupo, gIdx) => {
                    const grupoDiv = document.createElement('div');
                    grupoDiv.className = 'grupo-variacao';
                    grupoDiv.style.marginBottom = '1rem';
                    grupoDiv.innerHTML = `<h3 style="font-size:0.9rem;">${grupo.nome}</h3><div class="opcoes-grupo" data-gidx="${gIdx}"></div>`;
                    const opcoesDiv = grupoDiv.querySelector('.opcoes-grupo');
                    grupo.opcoes.forEach((op, oIdx) => {
                        const div = document.createElement('div');
                        div.style.cssText =
                            'display:flex; justify-content:space-between; align-items:center; padding:0.3rem; border-bottom:1px solid #dee2e6;';
                        div.innerHTML =
                            `<span>${op.nome} <span style="color:#00aa66;">+R$ ${op.preco.toFixed(2)}</span></span><input type="checkbox" data-grupo="${gIdx}" data-op="${oIdx}" class="check-variacao" style="width:20px; height:20px;" aria-label="Selecionar ${op.nome}">`;
                        opcoesDiv.appendChild(div);
                    });
                    container.appendChild(grupoDiv);
                });
            }

            // Controle de quantidade
            const qtdInput = document.getElementById('quantidadeInput');
            const btnMenos = document.getElementById('qtdMenos');
            const btnMais = document.getElementById('qtdMais');

            function atualizarQuantidade() {
                let val = parseInt(qtdInput.value);
                if (isNaN(val) || val < 1) val = 1;
                if (val > 100) val = 100;
                qtdInput.value = val;
                quantidadeSelecionada = val;
            }

            btnMenos.onclick = function() {
                let val = parseInt(qtdInput.value) || 1;
                if (val > 1) val--;
                qtdInput.value = val;
                atualizarQuantidade();
            };
            btnMais.onclick = function() {
                let val = parseInt(qtdInput.value) || 1;
                if (val < 100) val++;
                qtdInput.value = val;
                atualizarQuantidade();
            };
            qtdInput.onchange = function() { atualizarQuantidade(); };
            qtdInput.value = 1;
            quantidadeSelecionada = 1;

            function updateGroupLimits() {
                if (gruposAtivos.length === 0) {
                    document.getElementById('btnConfirmarVariacoes').disabled = false;
                    return;
                }
                let allValid = true,
                    errorMsg = '';
                gruposAtivos.forEach((grupo, gIdx) => {
                    const groupDiv = document.querySelector(`.opcoes-grupo[data-gidx="${gIdx}"]`);
                    if (!groupDiv) return;
                    const checkboxes = groupDiv.querySelectorAll('.check-variacao');
                    const selectedCount = Array.from(checkboxes).filter(cb => cb.checked).length;
                    const max = grupo.max;
                    if (max > 0 && selectedCount >= max) {
                        checkboxes.forEach(cb => { if (!cb.checked) cb.disabled = true; });
                    } else {
                        checkboxes.forEach(cb => cb.disabled = false);
                    }
                    if (grupo.min > 0 && selectedCount < grupo.min) { allValid = false;
                        errorMsg = `Selecione pelo menos ${grupo.min} item(s) em "${grupo.nome}".`; }
                    if (max > 0 && selectedCount > max) { allValid = false;
                        errorMsg = `Selecione no máximo ${max} item(s) em "${grupo.nome}".`; }
                });
                document.getElementById('erroVariacao').innerHTML = errorMsg;
                document.getElementById('btnConfirmarVariacoes').disabled = !allValid;
            }

            document.querySelectorAll('.check-variacao').forEach(cb => {
                cb.removeEventListener('change', updateGroupLimits);
                cb.addEventListener('change', (e) => {
                    const grupoIdx = parseInt(e.target.dataset.grupo);
                    const grupo = gruposAtivos[grupoIdx];
                    const max = grupo.max;
                    if (max > 0) {
                        const groupDiv = document.querySelector(`.opcoes-grupo[data-gidx="${grupoIdx}"]`);
                        const selectedCount = Array.from(groupDiv.querySelectorAll('.check-variacao'))
                            .filter(c => c.checked).length;
                        if (e.target.checked && selectedCount > max) { e.target.checked = false;
                            alert(`Máximo ${max} item(s) em "${grupo.nome}".`); }
                    }
                    updateGroupLimits();
                });
            });
            updateGroupLimits();
            document.getElementById('variacaoTitulo').innerHTML = `➕ ${produto.nome}`;
            abrirModal('modalVariacoes');
        }

        function finalizarEscolhaVariacoes() {
            const produto = produtoParaAdicionar;
            if (!produto) return;
            const gruposRef = (produto.grupos || []).filter(g => g.ativo);
            const gruposAtivos = [];
            gruposRef.forEach(ref => {
                const v = variacoesGlobais.find(v => v.id === ref.id);
                if (v && v.ativo && v.opcoes.length) {
                    gruposAtivos.push({
                        id: v.id,
                        nome: v.nome,
                        ativo: true,
                        min: ref.min !== undefined ? ref.min : v.min,
                        max: ref.max !== undefined ? ref.max : v.max,
                        opcoes: v.opcoes
                    });
                }
            });

            const selecoes = [];
            for (let gIdx = 0; gIdx < gruposAtivos.length; gIdx++) {
                const grupo = gruposAtivos[gIdx];
                const checks = document.querySelectorAll(`.opcoes-grupo[data-gidx="${gIdx}"] .check-variacao`);
                const selected = Array.from(checks).filter(cb => cb.checked).map(cb => grupo.opcoes[parseInt(cb.dataset
                .op)]);
                const min = grupo.min,
                    max = grupo.max;
                if (min > 0 && selected.length < min) { alert(`Selecione pelo menos ${min} em ${grupo.nome}.`); return; }
                if (max > 0 && selected.length > max) { alert(`Máximo ${max} em ${grupo.nome}.`); return; }
                if (selected.length > 0) selecoes.push({ nomeGrupo: grupo.nome, itens: selected });
            }
            const qtdInput = document.getElementById('quantidadeInput');
            let quantidade = parseInt(qtdInput.value);
            if (isNaN(quantidade) || quantidade < 1) quantidade = 1;
            if (quantidade > 100) quantidade = 100;
            quantidadeSelecionada = quantidade;

            adicionarAoCarrinho(produto, selecoes, quantidade);
            fecharModal('modalVariacoes');
            produtoParaAdicionar = null;
        }

        function adicionarAoCarrinho(produto, variacoes, quantidade) {
            const valorAdicionais = variacoes.reduce((s, g) => s + g.itens.reduce((sum, i) => sum + i.preco, 0), 0);
            const precoUnit = produto.preco + valorAdicionais;
            const key = `${produto.id}_${JSON.stringify(variacoes)}`;
            const existente = carrinho.find(i => i.key === key);
            if (existente) {
                existente.quantidade += quantidade;
            } else {
                carrinho.push({ key, produtoId: produto.id, nome: produto.nome, precoBase: produto.preco, variacoes,
                    precoUnitario: precoUnit, quantidade: quantidade });
            }
            salvarCarrinho();
            renderizarPedido();
            atualizarTotalFlutuante();
            atualizarBadgeCarrinho();
            mostrarMsg(`✨ ${quantidade}x ${produto.nome} adicionado!`);
        }

        function removerItemCarrinho(key) {
            carrinho = carrinho.filter(i => i.key !== key);
            salvarCarrinho();
            renderizarPedido();
            atualizarTotalFlutuante();
            atualizarBadgeCarrinho();
        }

        function alterarQtd(key, delta) {
            const item = carrinho.find(i => i.key === key);
            if (item) {
                const nova = item.quantidade + delta;
                if (nova <= 0) removerItemCarrinho(key);
                else { item.quantidade = nova;
                    salvarCarrinho();
                    renderizarPedido();
                    atualizarTotalFlutuante();
                    atualizarBadgeCarrinho(); }
            }
        }

        function renderizarPedido() {
            const container = document.getElementById('listaPedido');
            if (!carrinho.length) container.innerHTML = '<div style="text-align:center;color:#6c757d;">Carrinho vazio</div>';
            else {
                container.innerHTML = '';
                carrinho.forEach(i => {
                    let variacoesHtml = '';
                    if (i.variacoes && i.variacoes.length) variacoesHtml =
                        '<div class="pedido-variacoes">📌 ' + i.variacoes.map(g =>
                            `${g.nomeGrupo}: ${g.itens.map(item => `${item.nome} (+R$ ${item.preco.toFixed(2)})`).join(', ')}`
                            ).join(' | ') + '</div>';
                    const div = document.createElement('div');
                    div.className = 'pedido-item';
                    div.setAttribute('role', 'listitem');
                    div.innerHTML = `
                        <div class="pedido-info">
                            <div class="pedido-nome">${i.nome}</div>
                            ${variacoesHtml}
                        </div>
                        <div class="pedido-preco">R$ ${(i.precoUnitario * i.quantidade).toFixed(2)}</div>
                        <div class="pedido-quantidade">
                            <button class="btn-qtd" onclick="alterarQtd('${i.key}',-1)" aria-label="Diminuir quantidade">-</button>
                            <span>${i.quantidade}</span>
                            <button class="btn-qtd" onclick="alterarQtd('${i.key}',1)" aria-label="Aumentar quantidade">+</button>
                            <button class="btn-remover-pedido" onclick="removerItemCarrinho('${i.key}')" aria-label="Remover item">✕</button>
                        </div>
                    `;
                    container.appendChild(div);
                });
            }
            atualizarTotalFlutuante();
        }

        function atualizarTotalFlutuante() {
            const total = carrinho.reduce((s, i) => s + i.precoUnitario * i.quantidade, 0);
            document.getElementById('totalFlutuante').innerHTML = `R$ ${total.toFixed(2)}`;
        }

        function atualizarBadgeCarrinho() {
            const totalItens = carrinho.reduce((s, i) => s + i.quantidade, 0);
            document.getElementById('carrinhoBadgeFloat').innerText = totalItens;
        }

        function mostrarMsg(msg) {
            const el = document.getElementById('mensagemFeedback');
            el.innerHTML = `💙 ${msg}`;
            setTimeout(() => el.innerHTML = '💙 Clique nos botões + ou - para alterar quantidade', 2000);
        }

        function toggleCarrinho() { document.getElementById('cartArea').classList.toggle('visible'); }

        function fecharCarrinho() { document.getElementById('cartArea').classList.remove('visible'); }

        // ================================================================
        //   QR CODE
        // ================================================================
        function gerarQRCodeReal(chave) {
            const container = document.getElementById('qrCodeContainer');
            container.innerHTML = '';
            if (typeof QRCode !== 'undefined') {
                try {
                    new QRCode(container, { text: chave, width: 150, height: 150 });
                } catch (e) {
                    container.innerHTML = '<div style="color:#999;">Erro ao gerar QR Code</div>';
                }
            } else {
                const canvas = document.createElement('canvas');
                canvas.width = 150;
                canvas.height = 150;
                const ctx = canvas.getContext('2d');
                ctx.fillStyle = 'white';
                ctx.fillRect(0, 0, canvas.width, canvas.height);
                ctx.fillStyle = 'black';
                for (let i = 0; i < 10; i++)
                    for (let j = 0; j < 10; j++)
                        if ((i + j) % 2 === 0) ctx.fillRect(15 + i * 12, 15 + j * 12, 8, 8);
                ctx.font = '10px monospace';
                ctx.fillStyle = 'black';
                ctx.fillText("PIX", 60, 140);
                container.appendChild(canvas);
            }
        }

        // ================================================================
