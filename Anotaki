        function renderizarOpcoesVariacaoGlobal(opcoes) {
            const container = document.getElementById('opcoesVariacaoGlobal');
            container.innerHTML = '';
            if (!opcoes.length) {
                container.innerHTML = '<div style="color:#6c757d;">Nenhuma opção adicionada.</div>';
                return;
            }
            opcoes.forEach((op, idx) => {
                const div = document.createElement('div');
                div.className = 'opcao-item';
                div.innerHTML = `
                    <input type="text" value="${op.nome.replace(/"/g, '&quot;')}" data-idx="${idx}" class="opcao-nome-global">
                    <input type="number" step="0.01" value="${op.preco}" data-idx="${idx}" class="opcao-preco-global">
                    <button class="btn-remover-opcao" data-idx="${idx}" style="background:#dc3545; border:none; color:white; width:28px; height:28px; border-radius:50%; cursor:pointer;">✕</button>
                `;
                container.appendChild(div);
            });
            document.querySelectorAll('.opcao-nome-global').forEach(inp => inp.onchange = function() {
                const idx = parseInt(this.dataset.idx);
                const opcoesAtuais = getOpcoesGlobais();
                opcoesAtuais[idx].nome = this.value;
            });
            document.querySelectorAll('.opcao-preco-global').forEach(inp => inp.onchange = function() {
                const idx = parseInt(this.dataset.idx);
                const opcoesAtuais = getOpcoesGlobais();
                opcoesAtuais[idx].preco = parseFloat(this.value) || 0;
            });
